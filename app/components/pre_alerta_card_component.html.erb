<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 hover:shadow-md transition-shadow">
  <%# Row 1: Titulo + Tipo Envio badge %>
  <div class="flex items-start justify-between mb-1">
    <p class="font-semibold text-gray-800 text-sm leading-tight"><%= pre_alerta.titulo.presence || pre_alerta.numero_documento %></p>
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-cec-navy/10 text-cec-navy ring-1 ring-cec-navy/20 shrink-0 ml-2"><%= tipo_envio_badge_text %></span>
  </div>

  <%# Row 2: Tipo envio description %>
  <p class="text-xs text-gray-500 mb-2"><%= tipo_envio_description %></p>

  <%# Row 3: Info line (proveedor · PA number · date) %>
  <p class="text-xs text-gray-400 mb-3"><%= info_line %></p>

  <%# Row 4: Consolidation badge (right-aligned) %>
  <% badge = consolidation_badge %>
  <div class="flex justify-end mb-3">
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= badge[:bg] %> <%= badge[:text_color] %> ring-1 <%= badge[:ring] %>"><%= badge[:text] %></span>
  </div>

  <%# Row 5: Paquetes count + Estado %>
  <div class="flex items-center justify-between text-sm mb-3">
    <div class="flex items-center gap-1 text-gray-500">
      <%= helpers.heroicon "archive-box", variant: :outline, options: { class: "w-4 h-4" } %>
      <span><%= pre_alerta.pre_alerta_paquetes.size %> paquete(s)</span>
    </div>
    <%= render StatusBadgeComponent.new(status: pre_alerta.estado) %>
  </div>

  <%# Row 6: Actions %>
  <div class="pt-3 border-t border-gray-100 flex gap-2">
    <%= link_to helpers.cuenta_pre_alerta_path(pre_alerta),
        class: "text-xs text-gray-500 hover:text-gray-700 font-medium" do %>
      Ver detalle
    <% end %>
    <% unless pre_alerta.anulado? || pre_alerta.finalizado? %>
      <%= link_to helpers.edit_cuenta_pre_alerta_path(pre_alerta),
          class: "text-xs text-cec-teal hover:text-cec-teal-dark font-medium" do %>
        Editar
      <% end %>
    <% end %>
  </div>
</div>
