<%= form_with url: @url, method: :get, data: { turbo_frame: "_top" }, class: "w-full sm:max-w-md" do |f| %>
  <div class="relative">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
      <%= helpers.heroicon "magnifying-glass", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
    </div>
    <%= f.text_field @param, value: @value, placeholder: @placeholder,
        class: "block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg text-sm
               placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cec-navy focus:border-cec-navy",
        autocomplete: "off" %>
  </div>
<% end %>
