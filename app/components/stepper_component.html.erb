<div class="w-full">
  <%# Horizontal on sm+, vertical on mobile %>
  <ol class="hidden sm:flex items-start justify-between gap-2">
    <% steps.each_with_index do |step, i| %>
      <li class="flex-1 flex flex-col items-center relative">
        <div class="flex items-center w-full">
          <%# Left connector (hidden on first) %>
          <div class="flex-1 h-0.5 <%= i == 0 ? 'invisible' : connector_classes(step[:status]) %>"></div>

          <%# Circle %>
          <div class="flex items-center justify-center w-10 h-10 rounded-full border-2 font-bold text-sm transition-all duration-300 <%= circle_classes(step[:status]) %>">
            <% if step[:status] == :completed %>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            <% else %>
              <%= i + 1 %>
            <% end %>
          </div>

          <%# Right connector (hidden on last) %>
          <div class="flex-1 h-0.5 <%= i == steps.size - 1 ? 'invisible' : connector_classes(steps[i + 1][:status]) %>"></div>
        </div>
        <span class="mt-2 text-xs text-center <%= label_classes(step[:status]) %>">
          <%= step[:label] %>
        </span>
        <% if step[:detail].present? %>
          <span class="text-[10px] text-center <%= detail_classes(step[:status]) %>">
            <%= step[:detail] %>
          </span>
        <% end %>
      </li>
    <% end %>
  </ol>

  <%# Mobile: vertical compact list %>
  <ol class="sm:hidden space-y-3">
    <% steps.each_with_index do |step, i| %>
      <li class="flex items-center gap-3">
        <div class="flex items-center justify-center w-8 h-8 rounded-full border-2 font-bold text-xs shrink-0 <%= circle_classes(step[:status]) %>">
          <% if step[:status] == :completed %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          <% else %>
            <%= i + 1 %>
          <% end %>
        </div>
        <div>
          <span class="text-sm <%= label_classes(step[:status]) %>">
            <%= step[:label] %>
          </span>
          <% if step[:detail].present? %>
            <span class="block text-[10px] <%= detail_classes(step[:status]) %>">
              <%= step[:detail] %>
            </span>
          <% end %>
        </div>
      </li>
    <% end %>
  </ol>
</div>
