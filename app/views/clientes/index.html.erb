<%= render PageHeaderComponent.new(title: "Clientes", subtitle: "#{@clientes.total_count} clientes registrados") do |header|
  header.with_action do
    render ButtonComponent.new(variant: :gold, href: new_cliente_path, icon: "plus") do
      "Nuevo Cliente"
    end
  end
end %>

<div class="mb-6">
  <%= render SearchBarComponent.new(url: clientes_path, placeholder: "Buscar por codigo, nombre o email...", value: params[:q]) %>
</div>

<% if @clientes.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Codigo</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nombre</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden md:table-cell">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden lg:table-cell">Telefono</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden lg:table-cell">Categoria</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @clientes.each do |cliente| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm font-mono font-medium text-cec-navy"><%= cliente.codigo %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to cliente.nombre_completo, cliente, class: "text-sm font-medium text-gray-900 hover:text-cec-navy" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap hidden md:table-cell">
                <span class="text-sm text-gray-500"><%= cliente.email %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap hidden lg:table-cell">
                <span class="text-sm text-gray-500"><%= cliente.telefono %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap hidden lg:table-cell">
                <span class="text-sm text-gray-500"><%= cliente.categoria_precio&.nombre || "—" %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render StatusBadgeComponent.new(status: cliente.activo? ? "activo" : "inactivo") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <%= link_to edit_cliente_path(cliente), class: "text-gray-400 hover:text-cec-navy" do %>
                  <%= heroicon "pencil-square", variant: :outline, options: { class: "w-5 h-5 inline" } %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-4">
    <%= paginate @clientes %>
  </div>
<% else %>
  <%= render EmptyStateComponent.new(
    title: params[:q].present? ? "No se encontraron clientes" : "No hay clientes registrados",
    description: params[:q].present? ? "Intenta con otro termino de busqueda." : "Crea el primer cliente para comenzar.",
    icon: "users"
  ) do |empty|
    empty.with_action do
      render ButtonComponent.new(variant: :gold, href: new_cliente_path, icon: "plus") do
        "Nuevo Cliente"
      end
    end
  end %>
<% end %>
