<%= form_with model: cliente, class: "space-y-6" do |f| %>
  <% if cliente.errors.any? %>
    <div class="p-4 bg-red-50 rounded-lg">
      <div class="flex items-center gap-2 mb-2">
        <%= heroicon "exclamation-triangle", variant: :outline, options: { class: "w-5 h-5 text-red-600" } %>
        <h3 class="text-sm font-medium text-red-800">
          <%= pluralize(cliente.errors.count, "error") %> al guardar:
        </h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% cliente.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%# Codigo (read-only on edit) %>
    <div>
      <%= f.label :codigo, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <% if cliente.persisted? %>
        <p class="text-sm font-mono font-medium text-cec-navy py-2"><%= cliente.codigo %></p>
      <% else %>
        <%= f.text_field :codigo, placeholder: "Auto-generado si se deja vacio",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                   focus:ring-cec-navy focus:border-cec-navy" %>
        <p class="mt-1 text-xs text-gray-500">Dejar vacio para generar automaticamente (CEC-XXX)</p>
      <% end %>
    </div>

    <div></div>

    <div>
      <%= f.label :nombre, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :nombre, required: true,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div>
      <%= f.label :apellido, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :apellido,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div>
      <%= f.label :identidad, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :identidad,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div>
      <%= f.label :telefono, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :telefono,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div>
      <%= f.label :telefono_whatsapp, "WhatsApp", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :telefono_whatsapp,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :direccion, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :direccion, rows: 2,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div>
      <%= f.label :ciudad, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :ciudad,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div>
      <%= f.label :departamento, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :departamento,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-navy focus:border-cec-navy" %>
    </div>

    <div>
      <%= f.label :categoria_precio_id, "Categoria de Precio", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :categoria_precio_id, CategoriaPrecio.order(:nombre), :id, :nombre,
          { include_blank: "— Seleccionar —" },
          { class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                   focus:ring-cec-navy focus:border-cec-navy" } %>
    </div>

    <% if cliente.persisted? %>
      <div class="flex items-center gap-3">
        <%= f.check_box :activo, class: "rounded border-gray-300 text-cec-navy focus:ring-cec-navy" %>
        <%= f.label :activo, "Cliente activo", class: "text-sm font-medium text-gray-700" %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
    <%= link_to "Cancelar", cliente.persisted? ? cliente_path(cliente) : clientes_path,
        class: "text-sm text-gray-600 hover:text-gray-900" %>
    <%= f.submit cliente.persisted? ? "Guardar Cambios" : "Crear Cliente",
        class: "inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium
               bg-cec-gold text-cec-navy-dark hover:bg-cec-gold-dark transition-colors cursor-pointer" %>
  </div>
<% end %>
