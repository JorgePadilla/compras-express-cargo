<div class="max-w-3xl mx-auto bg-white p-8 shadow rounded-lg">
  <div class="flex justify-between items-start border-b border-gray-200 pb-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-cec-navy">Proforma</h1>
    </div>
    <div class="text-right">
      <p class="font-mono font-bold text-lg"><%= @proforma.numero %></p>
      <p class="text-sm text-gray-500"><%= @proforma.created_at.strftime("%d/%m/%Y") %></p>
    </div>
  </div>

  <% has_paquetes = @proforma.venta_items.any? { |i| i.paquete_id.present? } %>

  <table class="min-w-full border border-gray-200 mb-6">
    <thead class="bg-gray-50">
      <tr>
        <% if has_paquetes %>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-700 uppercase border-b">Guia</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-700 uppercase border-b">Tracking</th>
        <% end %>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-700 uppercase border-b">Concepto</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Peso</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Precio/Lb</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% @proforma.venta_items.each do |item| %>
        <tr>
          <% if has_paquetes %>
            <td class="px-4 py-2 text-sm font-mono"><%= item.paquete&.guia || "—" %></td>
            <td class="px-4 py-2 text-sm font-mono"><%= item.paquete ? truncate(item.paquete.tracking, length: 20) : "—" %></td>
          <% end %>
          <td class="px-4 py-2 text-sm"><%= item.concepto %></td>
          <td class="px-4 py-2 text-sm text-right"><%= item.peso_cobrar %></td>
          <td class="px-4 py-2 text-sm text-right"><%= @proforma.simbolo_moneda %> <%= number_with_delimiter(item.precio_libra.to_f, precision: 2) %></td>
          <td class="px-4 py-2 text-sm text-right"><%= @proforma.simbolo_moneda %> <%= number_with_delimiter(item.subtotal.to_f, precision: 2) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot class="bg-gray-50">
      <tr>
        <td colspan="<%= has_paquetes ? 5 : 3 %>" class="px-4 py-2 text-right font-bold">Total</td>
        <td class="px-4 py-2 text-right font-bold text-cec-navy"><%= @proforma.simbolo_moneda %> <%= number_with_delimiter(@proforma.total.to_f, precision: 2) %></td>
      </tr>
    </tfoot>
  </table>

  <div class="flex flex-wrap gap-3">
    <%= link_to "Descargar PDF", pdf_cuenta_proforma_path(@proforma), class: "px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium" %>
    <%= link_to "Volver", cuenta_proformas_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
</div>
