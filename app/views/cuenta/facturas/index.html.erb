<%= render PageHeaderComponent.new(title: "Mis Facturas", subtitle: "#{@ventas.total_count} facturas") %>

<% if current_cliente.saldo_pendiente.to_f > 0 %>
  <div class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
    <p class="text-sm text-amber-800">
      Tienes un saldo pendiente de
      <strong>L. <%= number_with_delimiter(current_cliente.saldo_pendiente.to_f, precision: 2) %></strong>
    </p>
  </div>
<% end %>

<div class="mb-4 flex gap-2">
  <%= link_to "Todas", cuenta_facturas_path, class: "px-3 py-1.5 text-sm rounded-lg #{params[:estado].blank? ? 'bg-cec-navy text-white' : 'bg-white text-gray-600 border border-gray-200'}" %>
  <%= link_to "Pendientes", cuenta_facturas_path(estado: "pendiente"), class: "px-3 py-1.5 text-sm rounded-lg #{params[:estado] == 'pendiente' ? 'bg-cec-navy text-white' : 'bg-white text-gray-600 border border-gray-200'}" %>
  <%= link_to "Pagadas", cuenta_facturas_path(estado: "pagada"), class: "px-3 py-1.5 text-sm rounded-lg #{params[:estado] == 'pagada' ? 'bg-cec-navy text-white' : 'bg-white text-gray-600 border border-gray-200'}" %>
</div>

<% if @ventas.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Numero</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Saldo</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @ventas.each do |v| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to v.numero, cuenta_factura_path(v), class: "text-sm font-mono font-medium text-cec-navy hover:underline" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= v.created_at.strftime("%d/%m/%Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render StatusBadgeComponent.new(status: v.estado) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">L. <%= number_with_delimiter(v.total.to_f, precision: 2) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium <%= v.saldo_pendiente.to_f > 0 ? "text-amber-700" : "text-cec-teal-dark" %>">
                L. <%= number_with_delimiter(v.saldo_pendiente.to_f, precision: 2) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-4"><%= paginate @ventas %></div>
<% else %>
  <%= render EmptyStateComponent.new(
    title: "No tienes facturas",
    description: "Aqui apareceran tus facturas cuando el equipo de Compras Express procese tus paquetes.",
    icon: "currency-dollar"
  ) %>
<% end %>
