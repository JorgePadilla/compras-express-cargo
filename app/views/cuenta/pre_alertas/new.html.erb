<% step = (params[:step] || params[:wizard_step] || 1).to_i %>
<% wizard = session[:pre_alerta_wizard] || {} %>

<%
  selected_tipo = wizard["tipo_envio_id"].present? ? TipoEnvio.find_by(id: wizard["tipo_envio_id"]) : nil
  show_consolidacion = selected_tipo.nil? || selected_tipo.consolidable
  status_for = ->(i) { step == i ? :active : (step > i ? :completed : :upcoming) }
  stepper_steps = [
    { label: "Servicio",          status: status_for.call(1) },
    ({ label: "Consolidación",    status: status_for.call(2) } if show_consolidacion),
    { label: "Datos del paquete", status: status_for.call(3) }
  ].compact

  # Canonical v4 service descriptions (short one-liners per pre_alerta_v4.docx)
  servicio_descripciones = {
    "express" => "Aéreo express — sale los viernes. El más rápido.",
    "cer"     => "Aéreo estándar. Balance entre precio y tiempo.",
    "cem"     => "Marítimo. La opción más económica con reempaque.",
    "cka"     => "Aéreo sin reempaque. Tu caja llega tal como la enviaste.",
    "ckm"     => "Marítimo sin reempaque. Económico y sin manipulación."
  }
%>

<%= render PageHeaderComponent.new(title: "Nueva Pre-Alerta", subtitle: "Sigue los pasos para crear tu pre-alerta") %>

<div class="max-w-4xl mx-auto" data-controller="wizard">
  <%# Sticky stepper %>
  <div class="sticky top-0 z-10 -mx-4 sm:mx-0 px-4 sm:px-0 py-4 bg-gradient-to-b from-white via-white to-white/80 backdrop-blur-sm mb-6">
    <%= render StepperComponent.new(steps: stepper_steps) %>
  </div>

  <%# ============================== %>
  <%#  STEP 1 — Servicio             %>
  <%# ============================== %>
  <% if step == 1 %>
    <%
      all_tipos  = TipoEnvio.activos.order(:nombre)
      con_reempaque_tipos = all_tipos.select { |t| t.con_reempaque }
      sin_reempaque_tipos = all_tipos.reject { |t| t.con_reempaque }
    %>
    <%= form_with url: cuenta_pre_alertas_path, method: :post, class: "space-y-6 animate-fade-in-up" do |f| %>
      <%= hidden_field_tag :wizard_step, 1 %>

      <div class="bg-gradient-to-br from-white to-gray-50 rounded-2xl p-6 sm:p-8 shadow-sm border border-gray-100">
        <div class="mb-6">
          <h2 class="text-xl sm:text-2xl font-bold text-cec-navy mb-2">Elige tu servicio</h2>
          <p class="text-sm text-gray-600 leading-relaxed">
            Selecciona cómo quieres que se envíen tus paquetes.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" data-wizard-target="options">
          <%# ---------- Grupo izquierdo: con reempaque + opción a consolidar ---------- %>
          <div class="rounded-2xl border border-cec-navy/10 overflow-hidden bg-white shadow-sm">
            <div class="bg-gradient-to-r from-cec-navy to-cec-navy-light px-5 py-3">
              <p class="text-sm font-bold text-white">Con reempaque unitario</p>
              <p class="text-xs text-white/70 mt-0.5">+ opción a consolidar</p>
            </div>
            <div class="p-4 space-y-3">
              <% con_reempaque_tipos.each do |tipo| %>
                <%
                  codigo = tipo.codigo.to_s.downcase
                  accent = case codigo
                           when "express" then { bg: "bg-cec-gold/10", text: "text-cec-gold",      icon_bg: "bg-cec-gold/15" }
                           when "cer"     then { bg: "bg-cec-teal/10", text: "text-cec-teal",      icon_bg: "bg-cec-teal/15" }
                           when "cem"     then { bg: "bg-cec-navy/5",  text: "text-cec-navy",      icon_bg: "bg-cec-navy/10" }
                           else                { bg: "bg-slate-50",    text: "text-slate-600",     icon_bg: "bg-slate-100" }
                           end
                  is_maritimo = tipo.modalidad == "maritimo"
                %>
                <label class="cursor-pointer group block">
                  <input type="radio" name="tipo_envio_id" value="<%= tipo.id %>" class="peer sr-only"
                         data-single-package="<%= tipo.single_package? %>"
                         <%= "checked" if wizard["tipo_envio_id"].to_s == tipo.id.to_s %>
                         data-action="change->wizard#selectService">
                  <div class="p-4 rounded-xl border-2 border-gray-200 bg-white
                              peer-checked:border-cec-gold peer-checked:bg-cec-gold/5 peer-checked:ring-2 peer-checked:ring-cec-gold/30
                              hover:shadow-lg hover:border-cec-gold/50 transition-all duration-200">
                    <div class="flex items-start gap-3">
                      <div class="shrink-0 w-11 h-11 rounded-xl <%= accent[:icon_bg] %> flex items-center justify-center">
                        <%= heroicon(is_maritimo ? "truck" : "paper-airplane", variant: :outline,
                            options: { class: "w-6 h-6 #{accent[:text]}" }) %>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="font-bold text-cec-navy text-base"><%= tipo.nombre %></p>
                        <% if (desc = servicio_descripciones[codigo]).present? %>
                          <p class="text-xs text-gray-600 mt-0.5 leading-snug"><%= desc %></p>
                        <% end %>
                        <% if tipo.precio_libra.present? %>
                          <p class="text-sm font-semibold <%= accent[:text] %> mt-1">$<%= "%.2f" % tipo.precio_libra %><span class="text-xs text-gray-500 font-normal">/lb</span></p>
                        <% end %>
                        <% if tipo.sla.present? %>
                          <p class="text-xs text-gray-500 mt-0.5 inline-flex items-center gap-1">
                            <%= heroicon "clock", variant: :outline, options: { class: "w-3 h-3" } %>
                            <%= tipo.sla %>
                          </p>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </label>
              <% end %>
            </div>
          </div>

          <%# ---------- Grupo derecho: sin reempaque — sin consolidar ---------- %>
          <div class="rounded-2xl border border-slate-200 overflow-hidden bg-white shadow-sm">
            <div class="bg-slate-50 border-b border-slate-200 px-5 py-3">
              <p class="text-sm font-bold text-slate-700">Sin reempaque</p>
              <p class="text-xs text-slate-500 mt-0.5">sin consolidar</p>
            </div>
            <div class="p-4 space-y-3">
              <% sin_reempaque_tipos.each do |tipo| %>
                <%
                  codigo = tipo.codigo.to_s.downcase
                  is_maritimo = tipo.modalidad == "maritimo"
                %>
                <label class="cursor-pointer group block">
                  <input type="radio" name="tipo_envio_id" value="<%= tipo.id %>" class="peer sr-only"
                         data-single-package="<%= tipo.single_package? %>"
                         <%= "checked" if wizard["tipo_envio_id"].to_s == tipo.id.to_s %>
                         data-action="change->wizard#selectService">
                  <div class="p-4 rounded-xl border-2 border-gray-200 bg-white
                              peer-checked:border-cec-gold peer-checked:bg-cec-gold/5 peer-checked:ring-2 peer-checked:ring-cec-gold/30
                              hover:shadow-lg hover:border-cec-gold/50 transition-all duration-200">
                    <div class="flex items-start gap-3">
                      <div class="shrink-0 w-11 h-11 rounded-xl bg-gray-100 flex items-center justify-center">
                        <%= heroicon(is_maritimo ? "truck" : "paper-airplane", variant: :outline,
                            options: { class: "w-6 h-6 text-gray-600" }) %>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                          <p class="font-bold text-cec-navy text-base"><%= tipo.nombre %></p>
                          <% if tipo.single_package? %>
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-50 text-red-700 ring-1 ring-red-200 uppercase tracking-wide">
                              1 paquete
                            </span>
                          <% end %>
                        </div>
                        <% if (desc = servicio_descripciones[codigo]).present? %>
                          <p class="text-xs text-gray-600 mt-0.5 leading-snug"><%= desc %></p>
                        <% end %>
                        <% if tipo.precio_libra.present? %>
                          <p class="text-sm font-semibold text-gray-700 mt-1">$<%= "%.2f" % tipo.precio_libra %><span class="text-xs text-gray-500 font-normal">/lb</span></p>
                        <% end %>
                        <% if tipo.sla.present? %>
                          <p class="text-xs text-gray-500 mt-0.5 inline-flex items-center gap-1">
                            <%= heroicon "clock", variant: :outline, options: { class: "w-3 h-3" } %>
                            <%= tipo.sla %>
                          </p>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </label>
              <% end %>
            </div>
          </div>
        </div>

        <%# Red banner: shown only when CKA/CKM is selected %>
        <%
          preselected_single = selected_tipo&.single_package?
        %>
        <div data-wizard-target="limitWarning"
             class="<%= preselected_single ? '' : 'hidden' %> mt-6 rounded-xl border-2 border-red-300 bg-red-50 p-4 animate-fade-in-up">
          <div class="flex items-start gap-3">
            <%= heroicon "exclamation-triangle", variant: :outline, options: { class: "w-6 h-6 text-red-500 shrink-0" } %>
            <div>
              <p class="font-bold text-red-700">1 paquete por acción</p>
              <p class="text-sm text-red-600 mt-0.5">CKA y CKM no permiten más de un tracking por pre-alerta.</p>
            </div>
          </div>
        </div>

        <%# Card footer — back link %>
        <div class="mt-8 -mx-6 sm:-mx-8 px-6 sm:px-8 pt-5 border-t border-gray-200 flex justify-start">
          <%= render ButtonComponent.new(
                variant: :ghost, size: :lg, icon: "arrow-left",
                href: cuenta_pre_alertas_path) do %>
            Mis Pre-Alertas
          <% end %>
        </div>
      </div>
    <% end %>

  <%# ============================== %>
  <%#  STEP 2 — Consolidación        %>
  <%# ============================== %>
  <% elsif step == 2 %>
    <%= form_with url: cuenta_pre_alertas_path, method: :post, class: "space-y-6 animate-fade-in-up" do |f| %>
      <%= hidden_field_tag :wizard_step, 2 %>
      <div class="bg-gradient-to-br from-white to-gray-50 rounded-2xl p-6 sm:p-8 shadow-sm border border-gray-100">
        <div class="mb-6">
          <h2 class="text-xl sm:text-2xl font-bold text-cec-navy mb-2">¿Deseas consolidar?</h2>
          <p class="text-sm text-gray-600 leading-relaxed">
            Consolidar agrupa múltiples paquetes en un solo envío para optimizar tu espacio y reducir costos.
          </p>
          <p class="text-xs text-gray-500 mt-1">Aplica a EXPRESS · CER · CEM</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-wizard-target="options">
          <label class="cursor-pointer group">
            <input type="radio" name="consolidado" value="1" class="peer sr-only"
                   <%= "checked" if wizard["consolidado"] %>
                   data-action="change->wizard#selectOption">
            <div class="h-full p-5 rounded-xl border-2 border-gray-200 bg-white
                        peer-checked:border-cec-gold peer-checked:bg-cec-gold/5 peer-checked:ring-2 peer-checked:ring-cec-gold/30
                        hover:shadow-xl hover:border-cec-gold/50 transition-all duration-200">
              <div class="flex items-start gap-4">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-cec-gold/10 flex items-center justify-center group-hover:bg-cec-gold/20 transition-colors">
                  <%= heroicon "squares-plus", variant: :outline, options: { class: "w-7 h-7 text-cec-gold" } %>
                </div>
                <div class="flex-1">
                  <p class="font-bold text-cec-navy">Sí, consolidar</p>
                  <p class="text-xs text-gray-500 mt-1">Agrupar paquetes en un solo envío</p>
                </div>
              </div>
            </div>
          </label>

          <label class="cursor-pointer group">
            <input type="radio" name="consolidado" value="0" class="peer sr-only"
                   <%= "checked" if wizard.key?("consolidado") && !wizard["consolidado"] %>
                   data-action="change->wizard#selectOption">
            <div class="h-full p-5 rounded-xl border-2 border-gray-200 bg-white
                        peer-checked:border-cec-gold peer-checked:bg-cec-gold/5 peer-checked:ring-2 peer-checked:ring-cec-gold/30
                        hover:shadow-xl hover:border-cec-gold/50 transition-all duration-200">
              <div class="flex items-start gap-4">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-gray-100 flex items-center justify-center group-hover:bg-gray-200 transition-colors">
                  <%= heroicon "archive-box", variant: :outline, options: { class: "w-7 h-7 text-gray-500" } %>
                </div>
                <div class="flex-1">
                  <p class="font-bold text-cec-navy">Sin consolidar</p>
                  <p class="text-xs text-gray-500 mt-1">Enviar por separado</p>
                </div>
              </div>
            </div>
          </label>
        </div>

        <%# Card footer — back link %>
        <div class="mt-8 -mx-6 sm:-mx-8 px-6 sm:px-8 pt-5 border-t border-gray-200 flex justify-start">
          <%= render ButtonComponent.new(
                variant: :ghost, size: :lg, icon: "arrow-left",
                href: new_cuenta_pre_alerta_path(step: 1)) do %>
            Atrás
          <% end %>
        </div>
      </div>
    <% end %>

  <%# ============================== %>
  <%#  STEP 3 — Datos del paquete    %>
  <%# ============================== %>
  <% elsif step == 3 %>
    <%
      back_step = (selected_tipo && selected_tipo.consolidable) ? 2 : 1
    %>
    <%= form_with url: cuenta_pre_alertas_path, method: :post, class: "space-y-6 animate-fade-in-up" do |f| %>
      <%= hidden_field_tag :wizard_step, 3 %>

      <div class="bg-gradient-to-br from-white to-gray-50 rounded-2xl p-6 sm:p-8 shadow-sm border border-gray-100">
        <div class="mb-6">
          <h2 class="text-xl sm:text-2xl font-bold text-cec-navy mb-2">Datos del paquete</h2>
          <p class="text-sm text-gray-600 leading-relaxed">
            Puedes dejar el tracking vacío y agregarlo después.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-5">
          <%# Tracking %>
          <label class="block">
            <span class="block text-sm font-semibold text-cec-navy mb-1.5">
              ¿Tienes número de tracking? <span class="text-xs font-normal text-gray-500">(opcional)</span>
            </span>
            <input type="text" name="tracking" value="<%= h(params[:tracking]) %>"
                   placeholder="Ej. 1Z999AA1..."
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm
                          focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
          </label>

          <%# Descripción %>
          <label class="block">
            <span class="block text-sm font-semibold text-cec-navy mb-1.5">Descripción</span>
            <textarea name="descripcion" rows="2" placeholder="¿Qué contiene el paquete?"
                      class="block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm
                             focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal"><%= h(params[:descripcion]) %></textarea>
          </label>

          <%# Instrucciones %>
          <label class="block">
            <span class="block text-sm font-semibold text-cec-navy mb-1.5">
              Instrucciones <span class="text-xs font-normal text-gray-500">(opcional)</span>
            </span>
            <textarea name="instrucciones" rows="2"
                      placeholder="Instrucciones para el procesamiento del paquete..."
                      class="block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm
                             focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal"><%= h(params[:instrucciones]) %></textarea>
          </label>

          <%# Valor declarado + Peso en fila %>
          <div class="grid grid-cols-2 gap-4">
            <label class="block">
              <span class="block text-sm font-semibold text-cec-navy mb-1.5">Valor declarado</span>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">$</span>
                <input type="number" step="0.01" min="0" name="valor_declarado" value="<%= h(params[:valor_declarado]) %>"
                       placeholder="0.00"
                       class="block w-full rounded-lg border border-gray-300 pl-7 pr-3 py-2.5 text-sm
                              focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
              </div>
            </label>
            <label class="block">
              <span class="block text-sm font-semibold text-cec-navy mb-1.5">Peso</span>
              <div class="relative">
                <input type="number" step="0.01" min="0" name="peso" value="<%= h(params[:peso]) %>"
                       placeholder="0.00"
                       class="block w-full rounded-lg border border-gray-300 px-3 pr-10 py-2.5 text-sm
                              focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">lb</span>
              </div>
            </label>
          </div>
        </div>

        <% if defined?(@pre_alerta) && @pre_alerta&.errors&.any? %>
          <div class="mt-5 bg-red-50 border border-red-200 rounded-xl p-4">
            <ul class="text-sm text-red-700 space-y-1">
              <% @pre_alerta.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <% if current_cliente.respond_to?(:notas_miami) && current_cliente.notas_miami.present? %>
          <div class="mt-5 rounded-xl border border-amber-200 bg-amber-50 p-4">
            <div class="flex items-start gap-3">
              <%= heroicon "information-circle", variant: :outline, options: { class: "w-5 h-5 text-amber-600 shrink-0 mt-0.5" } %>
              <div class="flex-1">
                <p class="text-xs font-semibold text-amber-800 uppercase tracking-wide mb-1">Notas de tu cuenta</p>
                <p class="text-sm text-amber-900 leading-relaxed"><%= simple_format(current_cliente.notas_miami) %></p>
              </div>
            </div>
          </div>
        <% end %>

        <%# Card footer — integrated action bar %>
        <div class="mt-8 -mx-6 sm:-mx-8 px-6 sm:px-8 pt-5 border-t border-gray-200 flex flex-col-reverse sm:flex-row sm:justify-between gap-3">
          <%= render ButtonComponent.new(
                variant: :ghost, size: :lg, icon: "arrow-left",
                href: new_cuenta_pre_alerta_path(step: back_step)) do %>
            Atrás
          <% end %>
          <button type="submit" class="inline-flex items-center gap-2 rounded-lg transition-all duration-200 btn-gold-gradient text-cec-navy-dark font-semibold shadow-sm shadow-cec-gold/25 px-6 py-3 text-base">
            Crear pre-alerta
            <%= heroicon "check-circle", variant: :outline, options: { class: "w-5 h-5" } %>
          </button>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
