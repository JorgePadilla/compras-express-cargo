<% max_paquetes = @pre_alerta.consolidado? ? @pre_alerta.tipo_envio&.max_paquetes_por_accion : 1 %>
<div data-controller="pre-alerta-editor pre-alerta-mover pre-alerta-buscar"
     data-pre-alerta-editor-max-paquetes-value="<%= max_paquetes || -1 %>"
     data-pre-alerta-editor-consolidado-value="<%= @pre_alerta.consolidando? %>"
     data-pre-alerta-editor-auto-add-value="<%= params[:agregar] == "1" %>"
     data-pre-alerta-editor-cancel-url-value="<%= cuenta_pre_alertas_path %>"
     data-pre-alerta-editor-autosave-url-value="<%= cuenta_pre_alerta_path(@pre_alerta) %>"
     data-pre-alerta-mover-destinos-url-value="<%= destinos_disponibles_cuenta_pre_alerta_path(@pre_alerta) %>"
     data-pre-alerta-mover-mover-url-value="<%= mover_paquete_cuenta_pre_alerta_path(@pre_alerta) %>"
     data-pre-alerta-buscar-paquetes-url-value="<%= paquetes_disponibles_cuenta_pre_alerta_path(@pre_alerta) %>"
     data-pre-alerta-buscar-agregar-url-value="<%= agregar_paquete_cuenta_pre_alerta_path(@pre_alerta) %>">
  <div id="pre_alerta_header">
    <%= render "cuenta/pre_alertas/header", pre_alerta: @pre_alerta %>
  </div>

  <div id="flash"></div>

  <% if @pre_alerta.consolidando? %>
    <div data-pre-alerta-editor-target="status"
         class="text-xs text-gray-400 transition-opacity duration-300"></div>
  <% end %>

  <%= form_with model: @pre_alerta, url: cuenta_pre_alerta_path(@pre_alerta), method: :patch,
      data: { pre_alerta_editor_target: "form" }, class: "space-y-6" do |f| %>

    <%# Info row %>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
        <p class="text-xs text-gray-500">Numero</p>
        <p class="font-mono font-bold text-cec-navy"><%= @pre_alerta.numero_documento %></p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
        <p class="text-xs text-gray-500">Tipo Envio</p>
        <p class="font-medium text-gray-800"><%= @pre_alerta.tipo_envio.nombre %> — <%= @pre_alerta.tipo_envio_descripcion %></p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
        <p class="text-xs text-gray-500">Opciones</p>
        <div class="flex gap-2 mt-1">
          <% if @pre_alerta.con_reempaque? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-cec-teal/10 text-cec-teal-dark ring-1 ring-cec-teal/30">Reempaque</span>
          <% else %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 ring-1 ring-gray-200">Sin Reempaque</span>
          <% end %>
          <% if @pre_alerta.finalizado? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-cec-teal/10 text-cec-teal-dark ring-1 ring-cec-teal/30">Consolidado Finalizado</span>
          <% elsif @pre_alerta.consolidando? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-cec-gold/10 text-cec-gold-dark ring-1 ring-cec-gold/30">Consolidando</span>
          <% else %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 ring-1 ring-gray-200">Sin Consolidación</span>
          <% end %>
        </div>
      </div>
    </div>

    <%# Titulo + Proveedor %>
    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Título de Referencia</label>
          <% if @pre_alerta.consolidando? %>
            <%= f.text_field :titulo, placeholder: "Ej. Televisor, Zapatos...",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
          <% else %>
            <p class="text-sm text-gray-800 py-2"><%= @pre_alerta.titulo.presence || "—" %></p>
          <% end %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Proveedor / Tienda</label>
          <% if @pre_alerta.consolidando? %>
            <%= f.text_field :proveedor, placeholder: "Ej. Amazon, Best Buy...",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
          <% else %>
            <p class="text-sm text-gray-800 py-2"><%= @pre_alerta.proveedor.presence || "—" %></p>
          <% end %>
        </div>
      </div>
    </div>

    <%# Notas de Consolidacion (only for consolidated, non-finalized, no paquetes en_aduana+) %>
    <% if @pre_alerta.consolidado? %>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Notas de Consolidacion</label>
        <% if @pre_alerta.notas_editables? %>
          <%= f.text_area :notas_grupo, rows: 2,
              placeholder: "Notas opcionales para este grupo de paquetes...",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
        <% else %>
          <p class="text-sm text-gray-800 py-2"><%= @pre_alerta.notas_grupo.presence || "—" %></p>
        <% end %>
      </div>
    <% end %>

    <%# Historial de Movimientos (read-only, only when present) %>
    <% if @pre_alerta.historial.present? %>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Historial de Movimientos</label>
        <div class="bg-gray-50 rounded-lg p-3 text-xs font-mono text-gray-600 whitespace-pre-line"><%= @pre_alerta.historial %></div>
      </div>
    <% end %>

    <%# Paquetes table %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <h3 class="text-sm font-bold text-gray-800">Paquetes</h3>
          <span data-pre-alerta-editor-target="counter"
                class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500"></span>
        </div>
        <% if puede_buscar? %>
          <button type="button"
                  data-action="click->pre-alerta-buscar#open"
                  class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-semibold
                         text-cec-teal bg-cec-teal/10 hover:bg-cec-teal/20 ring-1 ring-cec-teal/30 transition-colors">
            <%= heroicon "magnifying-glass", variant: :outline, options: { class: "w-4 h-4" } %>
            Buscar Paquetes
          </button>
        <% end %>
      </div>
      <% if max_paquetes && max_paquetes > 0 %>
        <div data-pre-alerta-editor-target="limitMessage"
             class="hidden px-4 py-2 bg-amber-50 border-b border-amber-200 text-xs text-amber-800 flex items-center gap-2">
          <%= heroicon "information-circle", variant: :outline, options: { class: "w-4 h-4 shrink-0" } %>
          <span>Solo se permite <%= max_paquetes %> paquete<%= "s" if max_paquetes != 1 %> por pre-alerta.</span>
        </div>
      <% end %>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Tracking</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Descripcion</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Instrucciones</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
              <th class="px-4 py-2 text-center text-xs font-medium text-gray-500 uppercase">Estado</th>
              <th class="px-4 py-2"></th>
              <th class="px-4 py-2"></th>
            </tr>
          </thead>
          <tbody data-pre-alerta-editor-target="paquetesBody" class="divide-y divide-gray-200">
            <% @pre_alerta.pre_alerta_paquetes.each.with_index do |pap, index| %>
              <%= render "cuenta/pre_alertas/paquete_fields", f: f, pap: pap, index: index %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <% unless @pre_alerta.finalizado? %>
      <%# Template for new rows (hidden) %>
      <template data-pre-alerta-editor-target="template">
        <tr class="paquete-row" data-new-record="true">
          <td class="px-4 py-2">
            <input type="text" name="pre_alerta[pre_alerta_paquetes_attributes][NEW_INDEX][tracking]"
                   placeholder="Tracking"
                   class="block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                          focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
          </td>
          <td class="px-4 py-2">
            <input type="text" name="pre_alerta[pre_alerta_paquetes_attributes][NEW_INDEX][descripcion]"
                   placeholder="Descripcion"
                   class="block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                          focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
          </td>
          <td class="px-4 py-2">
            <textarea name="pre_alerta[pre_alerta_paquetes_attributes][NEW_INDEX][instrucciones]"
                      rows="2" placeholder="Instrucciones"
                      class="block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                             focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal"></textarea>
          </td>
          <td class="px-4 py-2">
            <span class="text-sm text-gray-500"><%= Date.current.strftime("%d/%m/%Y") %></span>
          </td>
          <td class="px-4 py-2 text-center">
            <%= render StatusBadgeComponent.new(status: "pre_alerta", label: "Pre Alerta") %>
          </td>
          <td class="px-4 py-2"></td>
          <td class="px-4 py-2 text-center">
            <button type="button" data-action="click->pre-alerta-editor#removePaquete"
                    class="text-red-400 hover:text-red-600">
              <%= heroicon "trash", variant: :outline, options: { class: "w-4 h-4" } %>
            </button>
          </td>
        </tr>
      </template>
    <% end %>

    <%# Action buttons %>
    <div class="flex flex-col sm:flex-row gap-3 justify-end">
      <%= link_to "Volver", cuenta_pre_alertas_path,
          class: "text-gray-600 hover:text-gray-800 text-sm font-medium px-4 py-2.5 text-center" %>
      <% if @pre_alerta.consolidando? %>
        <button type="button" data-action="click->pre-alerta-editor#addPaquete"
                data-pre-alerta-editor-target="addButton"
                class="inline-flex items-center gap-1.5 border border-cec-teal text-cec-teal font-semibold px-6 py-2.5 rounded-lg text-sm hover:bg-cec-teal/10 transition-colors">
          <%= heroicon "plus-circle", variant: :outline, options: { class: "w-4 h-4" } %>
          Agregar Paquete (F6)
        </button>
        <button type="button" data-action="click->pre-alerta-editor#finalizar"
                class="btn-gold-gradient text-cec-navy-dark font-semibold px-6 py-2.5 rounded-lg shadow-sm text-sm">
          Finalizar Consolidación (F9)
        </button>
      <% end %>
    </div>
  <% end %>

  <% unless @pre_alerta.finalizado? %>
    <%= render "cuenta/pre_alertas/move_modal", pre_alerta: @pre_alerta %>
  <% end %>

  <% if puede_buscar? %>
    <%= render "cuenta/pre_alertas/buscar_modal", pre_alerta: @pre_alerta %>
  <% end %>
</div>
