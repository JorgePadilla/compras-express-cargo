<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
  <div>
    <div class="flex items-center gap-3 flex-wrap">
      <h1 class="text-2xl font-bold text-gray-800">Pre-Alerta <%= pre_alerta.numero_documento %></h1>
      <%= render StatusBadgeComponent.new(status: pre_alerta.estado) %>
      <% if pre_alerta.finalizado? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-cec-teal/10 text-cec-teal-dark ring-1 ring-cec-teal/30">Consolidado Finalizado</span>
      <% elsif pre_alerta.consolidando? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-cec-gold/10 text-cec-gold-dark ring-1 ring-cec-gold/30">Consolidando</span>
      <% end %>
    </div>
    <p class="text-sm text-gray-500 mt-1">
      <span class="font-medium"><%= pre_alerta.tipo_envio.nombre %></span> — <%= pre_alerta.tipo_envio_descripcion %>
      · Creada el <%= l(pre_alerta.created_at, format: :short) rescue pre_alerta.created_at.strftime("%d/%m/%Y %H:%M") %>
      <% if pre_alerta.notificado? %>
        <span class="text-cec-teal-dark font-medium ml-2">Notificado</span>
      <% end %>
    </p>
  </div>
</div>
