<%= f.fields_for :pre_alerta_paquetes, pap, child_index: index do |pf| %>
  <tr class="paquete-row">
    <% if pap.persisted? %>
      <%= pf.hidden_field :id %>
    <% end %>
    <td class="px-4 py-2">
      <% if pap.paquete_id.present? %>
        <span class="font-mono text-sm text-gray-700"><%= pap.tracking %></span>
        <%= pf.hidden_field :tracking %>
      <% else %>
        <%= pf.text_field :tracking, placeholder: "Tracking (opcional)",
            class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                   focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
      <% end %>
    </td>
    <td class="px-4 py-2">
      <%= pf.text_field :descripcion, placeholder: "Descripcion",
          class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                 focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
    </td>
    <td class="px-4 py-2">
      <%= pf.text_field :instrucciones, placeholder: "Instrucciones",
          class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                 focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
    </td>
    <td class="px-4 py-2">
      <%= pf.number_field :valor_declarado, step: 0.01, min: 0, placeholder: "$",
          class: "block w-24 rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                 focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
    </td>
    <td class="px-4 py-2">
      <%= pf.number_field :peso, step: 0.01, min: 0, placeholder: "lb",
          class: "block w-20 rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                 focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
    </td>
    <td class="px-4 py-2 text-center">
      <%= pf.check_box :retener_miami, class: "rounded border-gray-300 text-cec-teal focus:ring-cec-teal" %>
    </td>
    <td class="px-4 py-2">
      <%= pf.date_field :fecha,
          class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                 focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal",
          data: { controller: "flatpickr" } %>
    </td>
    <td class="px-4 py-2 text-center">
      <% if pap.paquete_id.present? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-cec-teal/10 text-cec-teal-dark ring-1 ring-cec-teal/30">
          Vinculado
        </span>
      <% else %>
        <span class="text-xs text-gray-400">-</span>
      <% end %>
    </td>
    <td class="px-4 py-2 text-center">
      <% unless pap.paquete_id.present? %>
        <input type="hidden" name="pre_alerta[pre_alerta_paquetes_attributes][<%= index %>][_destroy]" value="0" data-pre-alerta-editor-target="destroyField">
        <button type="button" data-action="click->pre-alerta-editor#removePaquete"
                class="text-red-400 hover:text-red-600">
          <%= heroicon "trash", variant: :outline, options: { class: "w-4 h-4" } %>
        </button>
      <% end %>
    </td>
  </tr>
<% end %>
