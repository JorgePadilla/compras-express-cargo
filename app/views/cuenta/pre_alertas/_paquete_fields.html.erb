<%= f.fields_for :pre_alerta_paquetes, pap, child_index: index do |pf| %>
  <tr class="paquete-row" id="<%= "paquete_row_#{pap.id}" if pap.persisted? %>">
    <% if pap.persisted? %>
      <%= pf.hidden_field :id %>
    <% end %>
    <td class="px-4 py-2">
      <% if pap.paquete_id.present? %>
        <span class="font-mono text-sm text-gray-700"><%= pap.tracking %></span>
        <%= pf.hidden_field :tracking %>
      <% elsif puede_editar?(pap) %>
        <%= pf.text_field :tracking, placeholder: "Tracking (opcional)",
            class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                   focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
      <% else %>
        <span class="font-mono text-sm text-gray-700"><%= pap.tracking.presence || "—" %></span>
      <% end %>
    </td>
    <td class="px-4 py-2">
      <% if puede_editar?(pap) %>
        <%= pf.text_field :descripcion, placeholder: "Descripcion",
            class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                   focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
      <% else %>
        <span class="text-sm text-gray-700"><%= pap.descripcion.presence || "—" %></span>
      <% end %>
    </td>
    <td class="px-4 py-2">
      <% if puede_editar?(pap) %>
        <%= pf.text_area :instrucciones, placeholder: "Instrucciones", rows: 2,
            class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm
                   focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
      <% else %>
        <span class="text-sm text-gray-700"><%= pap.instrucciones.presence || "—" %></span>
      <% end %>
    </td>
    <td class="px-4 py-2">
      <span class="text-sm text-gray-500"><%= pap.fecha&.strftime("%d/%m/%Y") || "—" %></span>
    </td>
    <td class="px-4 py-2 text-center">
      <% if pap.paquete_id.present? %>
        <%= render StatusBadgeComponent.new(status: pap.paquete.estado) %>
      <% else %>
        <%= render StatusBadgeComponent.new(status: "pre_alerta", label: "Pre Alerta") %>
      <% end %>
    </td>
    <td class="px-4 py-2 text-center">
      <% if !@pre_alerta.finalizado? && pap.persisted? && puede_mover?(pap) %>
        <button type="button"
                data-action="click->pre-alerta-mover#open"
                data-pap-id="<%= pap.id %>"
                data-tracking="<%= pap.tracking %>"
                class="text-cec-teal hover:text-cec-teal-dark text-xs font-medium">
          Mover
        </button>
      <% end %>
    </td>
    <td class="px-4 py-2 text-center">
      <% if puede_eliminar?(pap) %>
        <% if pap.persisted? && pap.paquete_id.present? %>
          <%# Linked paquete in movible estado: server delete with long warning %>
          <%= button_to eliminar_paquete_cuenta_pre_alerta_path(@pre_alerta, pre_alerta_paquete_id: pap.id),
                method: :delete, class: "text-red-400 hover:text-red-600",
                data: { turbo_confirm: "¿Borrar este paquete de la pre-alerta? El paquete físico permanece en nuestra bodega. Si cambias de opinión tendrás que crear una nueva pre-alerta." } do %>
            <%= heroicon "trash", variant: :outline, options: { class: "w-4 h-4" } %>
          <% end %>
        <% elsif pap.persisted? && !@pre_alerta.consolidando? %>
          <%# Unlinked + not consolidando: server delete %>
          <%= button_to eliminar_paquete_cuenta_pre_alerta_path(@pre_alerta, pre_alerta_paquete_id: pap.id),
                method: :delete, class: "text-red-400 hover:text-red-600",
                data: { turbo_confirm: "¿Eliminar este paquete?" } do %>
            <%= heroicon "trash", variant: :outline, options: { class: "w-4 h-4" } %>
          <% end %>
        <% else %>
          <%# Unlinked + consolidando (or new row): JS-side remove keeps editor state %>
          <input type="hidden" name="pre_alerta[pre_alerta_paquetes_attributes][<%= index %>][_destroy]" value="0" data-pre-alerta-editor-target="destroyField">
          <button type="button" data-action="click->pre-alerta-editor#removePaquete"
                  class="text-red-400 hover:text-red-600">
            <%= heroicon "trash", variant: :outline, options: { class: "w-4 h-4" } %>
          </button>
        <% end %>
      <% end %>
    </td>
  </tr>
<% end %>
