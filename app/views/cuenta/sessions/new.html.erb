<div class="min-h-screen flex flex-col lg:flex-row">

  <%# ========== LEFT: Hero Section (desktop only) ========== %>
  <div class="hidden lg:flex lg:w-[55%] relative overflow-hidden">
    <%= image_tag "login-hero.jpg",
        alt: "Cargo containers",
        class: "object-cover w-full h-full absolute inset-0" %>
    <div class="absolute inset-0 bg-gradient-to-t from-cec-navy-dark/90 via-cec-navy/40 to-transparent"></div>
    <div class="absolute bottom-12 left-12 z-10">
      <h1 class="text-4xl font-bold text-white tracking-tight">Portal de Clientes</h1>
      <p class="text-lg text-gray-300 mt-2">Gestiona tus envios y pre-alertas.</p>
    </div>
  </div>

  <%# ========== MOBILE: Top banner ========== %>
  <div class="lg:hidden h-48 relative overflow-hidden">
    <%= image_tag "login-hero.jpg",
        alt: "Cargo containers",
        class: "object-cover w-full h-full" %>
    <div class="absolute inset-0 bg-cec-navy/70"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-white">
      <h1 class="text-2xl font-bold tracking-tight">Portal de Clientes</h1>
      <p class="text-sm text-gray-300 mt-1">Gestiona tus envios y pre-alertas.</p>
    </div>
  </div>

  <%# ========== RIGHT: Login Form ========== %>
  <div class="flex-1 flex items-center justify-center p-6 lg:p-12 bg-white relative">
    <div class="w-full max-w-md">

      <%# Logo icon %>
      <div class="flex items-center justify-center mb-8">
        <div class="w-14 h-14 bg-gradient-to-br from-cec-gold/20 to-cec-teal/10 rounded-2xl flex items-center justify-center shadow-lg shadow-cec-gold/10">
          <%= heroicon "user-circle", variant: :solid, options: { class: "w-8 h-8 text-cec-gold" } %>
        </div>
      </div>

      <%# Welcome heading %>
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-cec-navy">Bienvenido</h2>
        <p class="text-sm text-gray-500 mt-1">Inicia sesion en tu cuenta de cliente</p>
      </div>

      <%# Flash messages %>
      <% if alert = flash[:alert] %>
        <div class="mb-6 p-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl flex items-center gap-2">
          <%= heroicon "exclamation-circle", variant: :mini, options: { class: "w-5 h-5 shrink-0" } %>
          <span><%= alert %></span>
        </div>
      <% end %>
      <% if notice = flash[:notice] %>
        <div class="mb-6 p-3 bg-green-50 border border-green-200 text-green-700 text-sm rounded-xl flex items-center gap-2">
          <%= heroicon "check-circle", variant: :mini, options: { class: "w-5 h-5 shrink-0" } %>
          <span><%= notice %></span>
        </div>
      <% end %>

      <%# Login form %>
      <%= form_with url: cuenta_session_path, class: "space-y-5" do |form| %>
        <%# Email field %>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
            Correo electronico
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <%= heroicon "envelope", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
            </div>
            <%= form.email_field :email,
                required: true,
                autofocus: true,
                autocomplete: "username",
                placeholder: "tu@correo.com",
                class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                       transition-all duration-200
                       focus:border-cec-teal focus:ring-2 focus:ring-cec-teal/20 focus:outline-none
                       placeholder:text-gray-400" %>
          </div>
        </div>

        <%# Password field %>
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">
            Contrasena
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <%= heroicon "lock-closed", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
            </div>
            <%= form.password_field :password,
                required: true,
                autocomplete: "current-password",
                placeholder: "Ingrese su contrasena",
                maxlength: 72,
                class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                       transition-all duration-200
                       focus:border-cec-teal focus:ring-2 focus:ring-cec-teal/20 focus:outline-none
                       placeholder:text-gray-400" %>
          </div>
        </div>

        <%# Submit button %>
        <div>
          <button type="submit"
                  class="w-full rounded-xl btn-gold-gradient px-4 py-3 text-sm font-bold text-cec-navy-dark
                         shadow-md shadow-cec-gold/25 active:scale-[0.98] transition-all duration-200
                         cursor-pointer flex items-center justify-center gap-2">
            <span>Iniciar Sesion</span>
          </button>
        </div>
      <% end %>

      <%# Link to admin login %>
      <div class="text-center pt-4">
        <%= link_to "Acceso empleados", new_session_path,
            class: "text-sm text-gray-500 hover:text-cec-gold-dark transition-colors" %>
      </div>
    </div>

    <%# Footer %>
    <p class="absolute bottom-6 left-0 right-0 text-center text-xs text-gray-400">
      Compras Express Cargo &copy; <%= Date.current.year %>
    </p>
  </div>
</div>
