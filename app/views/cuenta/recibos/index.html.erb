<%= render PageHeaderComponent.new(title: "Mis Recibos", subtitle: "#{@recibos.total_count} recibos") %>

<% if @recibos.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Numero</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Venta</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Monto</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @recibos.each do |r| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to r.numero, cuenta_recibo_path(r), class: "text-sm font-mono font-medium text-cec-navy hover:underline" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-500">
              <%= link_to r.venta.numero, cuenta_factura_path(r.venta), class: "hover:underline" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= r.created_at.strftime("%d/%m/%Y") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              L. <%= number_with_delimiter(r.monto.to_f, precision: 2) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="mt-4"><%= paginate @recibos %></div>
<% else %>
  <%= render EmptyStateComponent.new(title: "No hay recibos", description: "Veras tus recibos aqui cuando realices pagos.", icon: "receipt-percent") %>
<% end %>
