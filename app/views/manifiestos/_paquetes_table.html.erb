<div class="bg-white rounded-lg shadow overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-800">Paquetes (<%= paquetes.size %>)</h2>
  </div>

  <% if paquetes.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Guia</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tracking</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cliente</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden md:table-cell">Peso</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
            <% if manifiesto.creado? %>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
            <% end %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% paquetes.each do |paquete| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm font-mono font-medium text-cec-navy"><%= paquete.guia %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm font-mono text-gray-700"><%= truncate(paquete.tracking, length: 25) %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-gray-700"><%= paquete.cliente.codigo %> — <%= paquete.cliente.nombre_completo %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap hidden md:table-cell">
                <span class="text-sm text-gray-700"><%= paquete.peso_cobrar || "—" %> lbs</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render StatusBadgeComponent.new(status: paquete.estado) %>
              </td>
              <% if manifiesto.creado? %>
                <td class="px-6 py-4 whitespace-nowrap text-right">
                  <%= link_to remove_paquete_manifiesto_path(manifiesto, paquete_id: paquete.id),
                      data: { turbo_method: :delete, turbo_confirm: "Remover #{paquete.guia} del manifiesto?" },
                      class: "text-red-400 hover:text-red-600" do %>
                    <%= heroicon "x-mark", variant: :outline, options: { class: "w-5 h-5 inline" } %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="p-6 text-center text-sm text-gray-500">
      No hay paquetes en este manifiesto
    </div>
  <% end %>
</div>
