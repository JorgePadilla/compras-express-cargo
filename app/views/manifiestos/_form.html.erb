<%= form_with model: manifiesto, class: "space-y-6" do |f| %>
  <% if manifiesto.errors.any? %>
    <div class="p-4 bg-red-50 rounded-lg">
      <div class="flex items-center gap-2 mb-2">
        <%= heroicon "exclamation-triangle", variant: :outline, options: { class: "w-5 h-5 text-red-600" } %>
        <h3 class="text-sm font-medium text-red-800">
          Se encontraron <%= manifiesto.errors.count %> error(es) al guardar:
        </h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% manifiesto.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :numero, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <% if manifiesto.persisted? %>
        <p class="text-sm font-mono font-medium text-cec-navy py-2"><%= manifiesto.numero %></p>
      <% else %>
        <%= f.text_field :numero, placeholder: "Auto-generado si se deja vacio",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                   focus:ring-cec-teal focus:border-cec-teal" %>
        <p class="mt-1 text-xs text-gray-500">Dejar vacio para generar automaticamente (MA-XXXXXX)</p>
      <% end %>
    </div>

    <div>
      <%= f.label :empresa_manifiesto_id, "Empresa", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :empresa_manifiesto_id, @empresas, :id, :nombre,
          { include_blank: "— Seleccionar —" },
          { class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                   focus:ring-cec-teal focus:border-cec-teal" } %>
    </div>

    <div>
      <%= f.label :tipo_envio, "Tipo de Envio", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :tipo_envio, @tipo_envios.map { |t| [t.nombre, t.nombre] },
          { include_blank: "— Seleccionar —" },
          { class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                   focus:ring-cec-teal focus:border-cec-teal" } %>
    </div>

    <div>
      <%= f.label :expedido_por, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :expedido_por,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" %>
    </div>

    <div>
      <%= f.label :numero_caja, "Numero de Caja", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :numero_caja,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" %>
    </div>

    <div>
      <%= f.label :numero_guia, "Numero de Guia", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :numero_guia,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" %>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
    <%= link_to "Cancelar", manifiesto.persisted? ? manifiesto_path(manifiesto) : manifiestos_path,
        class: "text-sm text-gray-600 hover:text-gray-900" %>
    <%= f.submit manifiesto.persisted? ? "Guardar Cambios" : "Crear Manifiesto",
        class: "inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium
               bg-cec-gold text-cec-navy-dark hover:bg-cec-gold-dark transition-colors cursor-pointer" %>
  </div>
<% end %>
