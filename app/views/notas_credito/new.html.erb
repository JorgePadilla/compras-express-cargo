<%= render PageHeaderComponent.new(title: "Nueva Nota de Credito", subtitle: @venta ? "Venta: #{@venta.numero}" : nil) %>

<% if @venta.nil? %>
  <div class="bg-white rounded-lg shadow p-6">
    <p class="text-sm text-gray-700 mb-4">Para crear una nota de credito, ingresa primero a la Venta y usa el boton "Crear Nota de Credito".</p>
    <%= link_to "Ver Ventas", ventas_path, class: "px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium" %>
  </div>
<% else %>
  <%= render "form", form_url: notas_credito_path, form_method: :post %>
<% end %>
