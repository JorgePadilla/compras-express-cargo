<%= render PageHeaderComponent.new(title: "Notas de Credito", subtitle: "#{@notas_credito.total_count} notas") %>

<div class="mb-6">
  <%= render SearchBarComponent.new(url: notas_credito_path, placeholder: "Buscar por numero, venta o cliente...", value: params[:q]) %>
</div>

<details class="mb-6 bg-white rounded-lg shadow">
  <summary class="px-6 py-3 cursor-pointer text-sm font-medium text-gray-700 hover:text-cec-navy flex items-center gap-2">
    <%= heroicon "funnel", variant: :outline, options: { class: "w-4 h-4" } %>
    Filtros
  </summary>
  <div class="px-6 py-4 border-t border-gray-200">
    <%= form_tag notas_credito_path, method: :get, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
        <%= select_tag :estado, options_for_select(NotaCredito::ESTADOS.map { |e| [e.humanize, e] }, params[:estado]),
            include_blank: "— Todos —",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-3 flex gap-3">
        <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg hover:bg-cec-navy-light text-sm font-medium">Aplicar</button>
        <%= link_to "Limpiar", notas_credito_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>
</details>

<% if @notas_credito.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Numero</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Venta</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cliente</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Motivo</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total (LPS)</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Acciones</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @notas_credito.each do |nc| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to nc.numero, nc, class: "text-sm font-mono font-medium text-cec-navy hover:underline" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to nc.venta.numero, venta_path(nc.venta), class: "text-sm font-mono text-cec-teal hover:underline" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-gray-700"><%= nc.cliente.codigo %></span>
                <span class="text-sm text-gray-500 hidden sm:inline ml-1"><%= nc.cliente.nombre_completo %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600"><%= nc.motivo&.humanize %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render StatusBadgeComponent.new(status: nc.estado) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                L. <%= number_with_delimiter(nc.total.to_f, precision: 2) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right space-x-2">
                <%= link_to "Ver", nc, class: "text-cec-teal hover:underline text-sm" %>
                <% if nc.creado? %>
                  <%= link_to "Editar", edit_nota_credito_path(nc), class: "text-cec-navy hover:underline text-sm" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-4"><%= paginate @notas_credito %></div>
<% else %>
  <%= render EmptyStateComponent.new(
    title: "No hay notas de credito",
    description: "Las notas de credito se emiten contra una Venta para reflejar devoluciones, descuentos o correcciones.",
    icon: "document-minus"
  ) %>
<% end %>
