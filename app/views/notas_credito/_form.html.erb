<%= form_with model: @nota_credito, url: form_url, method: form_method, local: true do |f| %>
  <% if @nota_credito.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm">
      <%= @nota_credito.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <% if @nota_credito.new_record? %>
    <%= hidden_field_tag :venta_id, @venta&.id %>
  <% end %>

  <div class="bg-white rounded-lg shadow p-6 mb-6 grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Venta</label>
      <p class="font-mono text-sm text-cec-navy"><%= @venta&.numero || @nota_credito.venta&.numero %></p>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Cliente</label>
      <p class="text-sm"><%= (@venta || @nota_credito.venta)&.cliente&.nombre_completo %></p>
    </div>
    <div>
      <%= f.label :motivo, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :motivo, options_for_select(NotaCredito::MOTIVOS.map { |m| [m.humanize, m] }, @nota_credito.motivo),
          { prompt: "— Selecciona —" },
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
    </div>
    <div>
      <%= f.label :moneda, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :moneda, value: @nota_credito.moneda || "LPS", readonly: true, class: "block w-full rounded-lg border-gray-300 bg-gray-50 text-sm" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :notas, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :notas, rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden mb-6">
    <div class="px-6 py-3 border-b border-gray-200 bg-gray-50 text-sm font-medium text-gray-700">Items</div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Concepto</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Peso</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Precio/Lb</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Subtotal</th>
          <th class="px-4 py-2"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <%= f.fields_for :nota_credito_items do |item_f| %>
          <tr>
            <td class="px-4 py-2">
              <%= item_f.hidden_field :id %>
              <%= item_f.text_field :concepto, class: "w-full rounded border-gray-300 text-sm" %>
            </td>
            <td class="px-4 py-2">
              <%= item_f.number_field :peso_cobrar, step: 0.01, class: "w-24 rounded border-gray-300 text-sm text-right" %>
            </td>
            <td class="px-4 py-2">
              <%= item_f.number_field :precio_libra, step: 0.01, class: "w-24 rounded border-gray-300 text-sm text-right" %>
            </td>
            <td class="px-4 py-2">
              <%= item_f.number_field :subtotal, step: 0.01, class: "w-28 rounded border-gray-300 text-sm text-right" %>
            </td>
            <td class="px-4 py-2 text-right">
              <% if item_f.object.persisted? %>
                <label class="text-xs text-red-600 inline-flex items-center gap-1">
                  <%= item_f.check_box :_destroy %> Eliminar
                </label>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="flex flex-wrap gap-3">
    <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium hover:bg-cec-navy-light">Guardar</button>
    <%= link_to "Cancelar", notas_credito_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
