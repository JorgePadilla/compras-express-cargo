<div class="max-w-3xl mx-auto bg-white p-8 print:p-0 print:shadow-none shadow rounded-lg">
  <div class="flex justify-between items-start border-b border-gray-200 pb-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-cec-navy">Compras Express Cargo</h1>
      <p class="text-sm text-gray-500">Nota de Credito</p>
    </div>
    <div class="text-right">
      <p class="font-mono font-bold text-lg"><%= @nota_credito.numero %></p>
      <p class="text-sm text-gray-500"><%= @nota_credito.created_at.strftime("%d/%m/%Y") %></p>
      <p class="text-sm mt-1"><%= render StatusBadgeComponent.new(status: @nota_credito.estado) %></p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6 text-sm">
    <div>
      <p class="text-gray-500">Cliente</p>
      <p class="font-medium"><%= @nota_credito.cliente.codigo %> — <%= @nota_credito.cliente.nombre_completo %></p>
    </div>
    <div class="text-right">
      <p class="text-gray-500">Venta origen</p>
      <p><%= link_to @nota_credito.venta.numero, venta_path(@nota_credito.venta), class: "font-mono text-cec-teal hover:underline" %></p>
    </div>
    <div>
      <p class="text-gray-500">Motivo</p>
      <p class="font-medium"><%= @nota_credito.motivo&.humanize %></p>
    </div>
    <% if @nota_credito.emitido_at %>
      <div class="text-right">
        <p class="text-gray-500">Emitido</p>
        <p><%= @nota_credito.emitido_at.strftime("%d/%m/%Y %H:%M") %></p>
      </div>
    <% end %>
  </div>

  <table class="min-w-full border border-gray-200 mb-6">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-700 uppercase border-b">Concepto</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Peso</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Precio/Lb</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% @nota_credito.nota_credito_items.each do |item| %>
        <tr>
          <td class="px-4 py-2 text-sm"><%= item.concepto %></td>
          <td class="px-4 py-2 text-sm text-right"><%= item.peso_cobrar %></td>
          <td class="px-4 py-2 text-sm text-right">
            <%= item.precio_libra.present? ? "L. #{number_with_delimiter(item.precio_libra.to_f, precision: 2)}" : "-" %>
          </td>
          <td class="px-4 py-2 text-sm text-right">L. <%= number_with_delimiter(item.subtotal.to_f, precision: 2) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot class="bg-gray-50">
      <tr>
        <td colspan="3" class="px-4 py-2 text-right text-sm">Subtotal</td>
        <td class="px-4 py-2 text-right text-sm">L. <%= number_with_delimiter(@nota_credito.subtotal.to_f, precision: 2) %></td>
      </tr>
      <tr>
        <td colspan="3" class="px-4 py-2 text-right text-sm">ISV (15%)</td>
        <td class="px-4 py-2 text-right text-sm">L. <%= number_with_delimiter(@nota_credito.impuesto.to_f, precision: 2) %></td>
      </tr>
      <tr>
        <td colspan="3" class="px-4 py-2 text-right font-bold">Total</td>
        <td class="px-4 py-2 text-right font-bold text-cec-navy">L. <%= number_with_delimiter(@nota_credito.total.to_f, precision: 2) %></td>
      </tr>
    </tfoot>
  </table>

  <% if @nota_credito.notas.present? %>
    <div class="mb-6 text-sm">
      <p class="text-gray-500 mb-1">Notas</p>
      <p class="text-gray-700 whitespace-pre-wrap"><%= @nota_credito.notas %></p>
    </div>
  <% end %>

  <div class="flex flex-wrap gap-3 print:hidden">
    <%= link_to "Descargar PDF", pdf_nota_credito_path(@nota_credito), class: "px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium" %>

    <% if @nota_credito.creado? %>
      <%= link_to "Editar", edit_nota_credito_path(@nota_credito), class: "px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50" %>
      <%= button_to "Emitir", emitir_nota_credito_path(@nota_credito), method: :post,
          class: "px-4 py-2 bg-cec-teal text-white rounded-lg text-sm font-medium hover:bg-cec-teal-dark",
          data: { turbo_confirm: "Al emitir se reduce el saldo pendiente del cliente y se envia email. Continuar?" } %>
    <% end %>

    <% if @nota_credito.emitido? %>
      <%= button_to "Reenviar Email", enviar_email_nota_credito_path(@nota_credito), method: :post,
          class: "px-4 py-2 bg-white border border-cec-teal text-cec-teal rounded-lg text-sm font-medium hover:bg-cec-teal/5" %>
      <%= button_to "Anular", anular_nota_credito_path(@nota_credito), method: :delete,
          class: "px-4 py-2 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm font-medium",
          data: { turbo_confirm: "Anular la nota de credito? Esto restaurara el saldo del cliente." } %>
    <% end %>

    <%= link_to "Volver", notas_credito_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
</div>
