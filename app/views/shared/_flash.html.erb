<% if local_assigns[:notice] %>
  <div class="p-3 bg-green-50 text-green-700 rounded-lg text-sm" data-controller="auto-dismiss">
    <%= notice %>
  </div>
<% end %>
<% if local_assigns[:alert] %>
  <div class="p-3 bg-red-50 text-red-700 rounded-lg text-sm" data-controller="auto-dismiss">
    <%= alert %>
  </div>
<% end %>
