<!DOCTYPE html>
<html lang="es">
<head>
  <title>Etiqueta - <%= @paquete.guia %></title>
  <meta charset="UTF-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, Helvetica, sans-serif; }
    @media print {
      @page { margin: 5mm; size: 4in 6in; }
      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
    @media screen {
      body { padding: 20px; max-width: 4in; margin: 0 auto; border: 1px dashed #ccc; }
    }
  </style>
</head>
<body>
  <%= yield %>
  <script>
    window.onload = function() { window.print(); }
  </script>
</body>
</html>
