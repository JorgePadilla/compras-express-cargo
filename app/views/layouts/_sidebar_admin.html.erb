<ul class="space-y-1 px-3">
  <%= sidebar_link "Home", root_path, icon: "home" %>

  <% if can_access?(:etiquetar) || can_access?(:manifiestos) || can_access?(:paquetes) %>
    <%= sidebar_section "Logistica" do %>
      <%= sidebar_link "Etiquetar", etiquetar_path, icon: "tag" if can_access?(:etiquetar) %>
      <%= sidebar_link "Manifiestos", manifiestos_path, icon: "cube" if can_access?(:manifiestos) %>
      <%= sidebar_link "Todos los Paquetes", paquetes_path, icon: "archive-box" if can_access?(:paquetes) %>
    <% end %>
  <% end %>

  <% if can_access?(:pre_facturas) || can_access?(:pre_alertas) || can_access?(:ventas) || can_access?(:notas_debito) || can_access?(:notas_credito) || can_access?(:cotizaciones) || can_access?(:financiamientos) %>
    <%= sidebar_section "Caja" do %>
      <%= sidebar_link "Pre-Facturas", pre_facturas_path, icon: "document-text" if can_access?(:pre_facturas) %>
      <%= sidebar_link "Pre-Alertas", pre_alertas_path, icon: "bell-alert" if can_access?(:pre_alertas) %>
      <%= sidebar_link "Cotizaciones", cotizaciones_path, icon: "clipboard-document-list" if can_access?(:cotizaciones) %>
      <%= sidebar_link "Proformas", proformas_path, icon: "document-duplicate" if can_access?(:ventas) %>
      <%= sidebar_link "Ventas", ventas_path, icon: "currency-dollar" if can_access?(:ventas) %>
      <%= sidebar_link "Recibos", recibos_path, icon: "receipt-percent" if can_access?(:recibos) %>
      <%= sidebar_link "Notas de Debito", notas_debito_path, icon: "document-plus" if can_access?(:notas_debito) %>
      <%= sidebar_link "Notas de Credito", notas_credito_path, icon: "document-minus" if can_access?(:notas_credito) %>
      <%= sidebar_link "Financiamientos", financiamientos_path, icon: "banknotes" if can_access?(:financiamientos) %>
    <% end %>
  <% end %>

  <%= sidebar_link "Clientes", clientes_path, icon: "users" if can_access?(:clientes) %>

  <% if can_access?(:entregas) %>
    <%= sidebar_link "Entregas", "#", icon: "truck" %>
  <% end %>

  <% if can_access?(:marketing) || admin? %>
    <%= sidebar_section "Marketing" do %>
      <%= sidebar_link "Correos", "#", icon: "envelope" %>
      <%= sidebar_link "WhatsApp", "#", icon: "chat-bubble-left-right" %>
      <%= sidebar_link "SMS", "#", icon: "device-phone-mobile" %>
    <% end %>
  <% end %>

  <% if admin? %>
    <%= sidebar_link "Usuarios", users_path, icon: "user-group" %>
    <%= sidebar_link "Categorias de Precio", categoria_precios_path, icon: "tag" %>
    <%= sidebar_link "Empresa", empresa_path, icon: "building-office-2" %>
    <%= sidebar_link "Configuraciones", "#", icon: "cog-6-tooth" %>
    <%= sidebar_link "Reportes", "#", icon: "table-cells" %>
  <% end %>
</ul>
