<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <title><%= content_for?(:title) ? yield(:title) : "Compras Express Cargo" %></title>
  </head>
  <body style="margin:0; padding:0; background:#f4f6f8; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color:#1f2937;">
    <% empresa = (Empresa.instance rescue nil) %>
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background:#f4f6f8;">
      <tr>
        <td align="center" style="padding:24px 12px;">
          <table role="presentation" cellpadding="0" cellspacing="0" width="600" style="max-width:600px; background:#ffffff; border-radius:8px; overflow:hidden; border:1px solid #e5e7eb;">
            <tr>
              <td style="background:#0f2b5b; padding:20px 24px; color:#ffffff;">
                <h1 style="margin:0; font-size:20px; font-weight:600;">
                  <%= empresa&.nombre || "Compras Express Cargo" %>
                </h1>
              </td>
            </tr>
            <tr>
              <td style="padding:24px;">
                <%= yield %>
              </td>
            </tr>
            <tr>
              <td style="padding:16px 24px; background:#f9fafb; border-top:1px solid #e5e7eb; font-size:12px; color:#6b7280;">
                <p style="margin:0 0 6px 0;">
                  <% if empresa&.direccion.present? %><%= empresa.direccion %><br><% end %>
                  <% if empresa&.telefono.present? %>Tel: <%= empresa.telefono %><% end %>
                  <% if empresa&.email_contacto.present? %> · <%= empresa.email_contacto %><% end %>
                </p>
                <p style="margin:0; color:#9ca3af;">
                  Si no deseas recibir estos correos, contacta a soporte para actualizar tus preferencias.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
