<%= form_with model: user, class: "space-y-6" do |f| %>
  <% if user.errors.any? %>
    <div class="p-4 bg-red-50 rounded-lg">
      <div class="flex items-center gap-2 mb-2">
        <%= heroicon "exclamation-triangle", variant: :outline, options: { class: "w-5 h-5 text-red-600" } %>
        <h3 class="text-sm font-medium text-red-800">
          Se encontraron <%= user.errors.count %> error(es) al guardar:
        </h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :nombre, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :nombre, required: true,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" %>
    </div>

    <div>
      <%= f.label :email_address, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email_address, required: true,
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" %>
    </div>

    <div>
      <%= f.label :password, "Contrasena", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, required: user.new_record?, autocomplete: "new-password",
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" %>
      <% if user.persisted? %>
        <p class="mt-1 text-xs text-gray-500">Dejar vacio para mantener la contrasena actual</p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirmar Contrasena", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, required: user.new_record?, autocomplete: "new-password",
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" %>
    </div>

    <div>
      <%= f.label :rol, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :rol, User.rol_options_for_select,
          { include_blank: "— Seleccionar Rol —" },
          { required: true, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" } %>
    </div>

    <div>
      <%= f.label :ubicacion, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :ubicacion, [["Miami", "miami"], ["Honduras", "honduras"]],
          { include_blank: "— Seleccionar Ubicacion —" },
          { class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm
                 focus:ring-cec-teal focus:border-cec-teal" } %>
    </div>

    <% if user.persisted? %>
      <div class="flex items-center gap-3">
        <%= f.check_box :activo, class: "rounded border-gray-300 text-cec-teal focus:ring-cec-teal" %>
        <%= f.label :activo, "Usuario activo", class: "text-sm font-medium text-gray-700" %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
    <%= link_to "Cancelar", user.persisted? ? user_path(user) : users_path,
        class: "text-sm text-gray-600 hover:text-gray-900" %>
    <%= f.submit user.persisted? ? "Guardar Cambios" : "Crear Usuario",
        class: "inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium
               bg-cec-gold text-cec-navy-dark hover:bg-cec-gold-dark transition-colors cursor-pointer" %>
  </div>
<% end %>
