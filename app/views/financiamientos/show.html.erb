<div class="max-w-3xl mx-auto">
  <div class="bg-white p-8 shadow rounded-lg mb-6">
    <div class="flex justify-between items-start border-b border-gray-200 pb-4 mb-6">
      <div>
        <h1 class="text-2xl font-bold text-cec-navy">Financiamiento</h1>
        <p class="text-sm text-gray-500"><%= @financiamiento.numero %></p>
      </div>
      <div class="text-right">
        <%= render StatusBadgeComponent.new(status: @financiamiento.estado) %>
        <p class="text-sm text-gray-500 mt-1"><%= @financiamiento.created_at.strftime("%d/%m/%Y") %></p>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6 text-sm">
      <div>
        <p class="text-gray-500">Cliente</p>
        <p class="font-medium"><%= @financiamiento.cliente.codigo %> — <%= @financiamiento.cliente.nombre_completo %></p>
      </div>
      <div>
        <p class="text-gray-500">Venta</p>
        <p class="font-mono"><%= link_to @financiamiento.venta.numero, venta_path(@financiamiento.venta), class: "text-cec-teal hover:underline" %></p>
      </div>
      <div>
        <p class="text-gray-500">Frecuencia</p>
        <p class="font-medium"><%= @financiamiento.frecuencia.capitalize %></p>
      </div>
      <div>
        <p class="text-gray-500">Cuotas</p>
        <p class="font-medium"><%= @financiamiento.numero_cuotas %></p>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <p class="text-xs text-gray-500 uppercase">Total</p>
        <p class="text-lg font-bold text-cec-navy"><%= @financiamiento.simbolo_moneda %> <%= number_with_delimiter(@financiamiento.monto_total.to_f, precision: 2) %></p>
      </div>
      <div class="bg-cec-teal/10 rounded-lg p-4 text-center">
        <p class="text-xs text-gray-500 uppercase">Pagado</p>
        <p class="text-lg font-bold text-cec-teal-dark"><%= @financiamiento.simbolo_moneda %> <%= number_with_delimiter(@financiamiento.monto_pagado.to_f, precision: 2) %></p>
      </div>
      <div class="bg-amber-50 rounded-lg p-4 text-center">
        <p class="text-xs text-gray-500 uppercase">Pendiente</p>
        <p class="text-lg font-bold text-amber-700"><%= @financiamiento.simbolo_moneda %> <%= number_with_delimiter(@financiamiento.monto_pendiente.to_f, precision: 2) %></p>
      </div>
    </div>

    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <div class="flex-1 bg-gray-200 rounded-full h-3">
          <div class="bg-cec-teal h-3 rounded-full transition-all" style="width: <%= @financiamiento.progreso_porcentaje %>%"></div>
        </div>
        <span class="text-sm font-medium text-gray-700"><%= @financiamiento.progreso_porcentaje %>%</span>
      </div>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden mb-6">
    <div class="px-6 py-3 border-b border-gray-200 bg-gray-50 text-sm font-medium text-gray-700">Cuotas</div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">#</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Vencimiento</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Monto</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Accion</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @cuotas.each do |cuota| %>
          <tr class="<%= cuota.vencida? ? 'bg-red-50' : '' %>">
            <td class="px-6 py-4 text-sm font-medium"><%= cuota.numero_cuota %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= cuota.fecha_vencimiento.strftime("%d/%m/%Y") %></td>
            <td class="px-6 py-4">
              <%= render StatusBadgeComponent.new(status: cuota.estado) %>
            </td>
            <td class="px-6 py-4 text-sm text-right font-medium">
              <%= @financiamiento.simbolo_moneda %> <%= number_with_delimiter(cuota.monto.to_f, precision: 2) %>
            </td>
            <td class="px-6 py-4 text-right">
              <% if (cuota.pendiente? || cuota.vencida?) && @financiamiento.activo? %>
                <%= form_with url: pagar_cuota_financiamiento_path(@financiamiento, cuota_id: cuota.id), method: :post, local: true, class: "inline-flex items-center gap-2" do %>
                  <%= select_tag :metodo_pago, options_for_select(Pago::METODOS.map { |m| [m.humanize, m] }),
                      class: "rounded border-gray-300 text-xs" %>
                  <button type="submit" class="px-3 py-1 bg-cec-teal text-white rounded text-xs font-medium hover:bg-cec-teal-dark"
                          data-turbo-confirm="¿Registrar pago de cuota <%= cuota.numero_cuota %>?">
                    Pagar
                  </button>
                <% end %>
              <% elsif cuota.pagada? %>
                <span class="text-xs text-cec-teal"><%= cuota.pagada_at&.strftime("%d/%m/%Y") %></span>
                <% if cuota.pago&.recibo %>
                  <%= link_to cuota.pago.recibo.numero, recibo_path(cuota.pago.recibo), class: "text-xs font-mono text-cec-teal hover:underline ml-1" %>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="flex flex-wrap gap-3">
    <% if @financiamiento.activo? %>
      <%= button_to "Cancelar Financiamiento", cancelar_financiamiento_path(@financiamiento), method: :delete,
          class: "px-4 py-2 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm font-medium",
          data: { turbo_confirm: "¿Cancelar este financiamiento?" } %>
    <% end %>
    <%= link_to "Volver", financiamientos_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
</div>
