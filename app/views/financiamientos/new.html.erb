<%= render PageHeaderComponent.new(title: "Nuevo Financiamiento") %>

<%= form_with model: @financiamiento, url: financiamientos_path, method: :post, local: true do |f| %>
  <% if @financiamiento.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm">
      <%= @financiamiento.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= f.hidden_field :venta_id %>
  <%= f.hidden_field :cliente_id %>

  <div class="bg-white rounded-lg shadow p-6 mb-6 grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Venta</label>
      <p class="font-mono text-sm text-cec-navy"><%= @venta&.numero || @financiamiento.venta&.numero %></p>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Cliente</label>
      <p class="text-sm"><%= (@venta || @financiamiento.venta)&.cliente&.nombre_completo %></p>
    </div>
    <div>
      <%= f.label :monto_total, "Monto Total", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :monto_total, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
    </div>
    <div>
      <%= f.label :moneda, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :moneda, readonly: true, class: "block w-full rounded-lg border-gray-300 bg-gray-50 text-sm" %>
    </div>
    <div>
      <%= f.label :numero_cuotas, "Numero de Cuotas", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :numero_cuotas, min: 1, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
    </div>
    <div>
      <%= f.label :frecuencia, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :frecuencia, options_for_select(Financiamiento::FRECUENCIAS.map { |fr| [fr.capitalize, fr] }, @financiamiento.frecuencia),
          {},
          class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
    </div>
    <div>
      <%= f.label :fecha_inicio, "Fecha de Inicio", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :fecha_inicio, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :notas, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :notas, rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
    </div>
  </div>

  <div class="flex flex-wrap gap-3">
    <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium hover:bg-cec-navy-light">Crear Financiamiento</button>
    <%= link_to "Cancelar", financiamientos_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
