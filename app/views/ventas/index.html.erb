<%= render PageHeaderComponent.new(title: "Ventas", subtitle: "#{@ventas.total_count} ventas") %>

<div class="mb-6">
  <%= render SearchBarComponent.new(url: ventas_path, placeholder: "Buscar por numero o cliente...", value: params[:q]) %>
</div>

<details class="mb-6 bg-white rounded-lg shadow">
  <summary class="px-6 py-3 cursor-pointer text-sm font-medium text-gray-700 hover:text-cec-navy flex items-center gap-2">
    <%= heroicon "funnel", variant: :outline, options: { class: "w-4 h-4" } %>
    Filtros
  </summary>
  <div class="px-6 py-4 border-t border-gray-200">
    <%= form_tag ventas_path, method: :get, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
        <%= select_tag :estado, options_for_select(Venta::ESTADOS.map { |e| [e.humanize, e] }, params[:estado]),
            include_blank: "— Todos —",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-3 flex gap-3">
        <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg hover:bg-cec-navy-light text-sm font-medium">Aplicar</button>
        <%= link_to "Limpiar", ventas_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>
</details>

<% if @ventas.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Numero</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cliente</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total (LPS)</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Saldo</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @ventas.each do |v| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to v.numero, v, class: "text-sm font-mono font-medium text-cec-navy hover:underline" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-gray-700"><%= v.cliente.codigo %></span>
                <span class="text-sm text-gray-500 hidden sm:inline ml-1"><%= v.cliente.nombre_completo %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-gray-500"><%= v.created_at.strftime("%d/%m/%Y") %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render StatusBadgeComponent.new(status: v.estado) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">L. <%= number_with_delimiter(v.total.to_f, precision: 2) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium <%= v.saldo_pendiente.to_f > 0 ? "text-amber-700" : "text-cec-teal-dark" %>">
                L. <%= number_with_delimiter(v.saldo_pendiente.to_f, precision: 2) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-4"><%= paginate @ventas %></div>
<% else %>
  <%= render EmptyStateComponent.new(
    title: "No hay ventas registradas",
    description: "Las ventas se generan al facturar una pre-factura.",
    icon: "currency-dollar"
  ) %>
<% end %>
