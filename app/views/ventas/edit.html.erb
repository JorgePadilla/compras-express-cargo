<%= render PageHeaderComponent.new(title: "Editar Venta #{@venta.numero}") %>

<%= form_with model: @venta, local: true do |f| %>
  <% if @venta.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm">
      <%= @venta.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <label class="block text-sm font-medium text-gray-700 mb-1">Notas</label>
    <%= f.text_area :notas, rows: 3, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
  </div>

  <div class="flex gap-3">
    <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium">Guardar</button>
    <%= link_to "Cancelar", venta_path(@venta), class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
