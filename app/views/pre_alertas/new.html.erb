<%= render PageHeaderComponent.new(title: "Nueva Pre-Alerta") %>

<div class="max-w-3xl">
  <%= form_with model: @pre_alerta, url: pre_alertas_path, class: "space-y-6" do |f| %>
    <% if @pre_alerta.errors.any? %>
      <div class="p-4 bg-red-50 border border-red-200 rounded-xl">
        <p class="text-sm font-medium text-red-700"><%= @pre_alerta.errors.full_messages.join(", ") %></p>
      </div>
    <% end %>

    <%# Client selector %>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 space-y-4">
      <h3 class="text-sm font-bold text-gray-800">Cliente</h3>
      <div data-controller="client-autocomplete" data-client-autocomplete-url-value="<%= buscar_clientes_path %>">
        <div class="relative">
          <input type="text" data-client-autocomplete-target="input" data-action="input->client-autocomplete#search"
                 placeholder="Buscar por codigo o nombre..."
                 autocomplete="off"
                 class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
          <%= f.hidden_field :cliente_id, data: { client_autocomplete_target: "clienteId" } %>
          <div data-client-autocomplete-target="dropdown" class="hidden absolute z-10 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-60 overflow-y-auto"></div>
        </div>
        <p data-client-autocomplete-target="nombre" class="mt-1 text-sm text-gray-500 hidden"></p>
      </div>
    </div>

    <%# Options %>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 space-y-4">
      <h3 class="text-sm font-bold text-gray-800">Opciones</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Envio</label>
          <%= f.select :tipo_envio_id, options_from_collection_for_select(@tipo_envios, :id, :nombre, @pre_alerta.tipo_envio_id),
              { include_blank: "— Seleccionar —" },
              class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:ring-cec-teal focus:border-cec-teal" %>
        </div>
        <div class="flex flex-col justify-end gap-3">
          <label class="flex items-center gap-2 text-sm">
            <%= f.check_box :con_reempaque, class: "rounded border-gray-300 text-cec-teal focus:ring-cec-teal" %>
            Con Reempaque
          </label>
          <label class="flex items-center gap-2 text-sm">
            <%= f.check_box :consolidado, class: "rounded border-gray-300 text-cec-teal focus:ring-cec-teal" %>
            Consolidado
          </label>
        </div>
      </div>
    </div>

    <%# Titulo + Proveedor %>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 space-y-4">
      <h3 class="text-sm font-bold text-gray-800">Referencia</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Título de Referencia</label>
          <%= f.text_field :titulo, placeholder: "Ej. Televisor, Zapatos...",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Proveedor / Tienda</label>
          <%= f.text_field :proveedor, placeholder: "Ej. Amazon, Best Buy...",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
        </div>
      </div>
    </div>

    <%# Notas %>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Notas del grupo</label>
      <%= f.text_area :notas_grupo, rows: 2,
          placeholder: "Notas opcionales...",
          class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                 focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
    </div>

    <%# Paquetes %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden" data-controller="pre-alerta-editor">
      <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <h3 class="text-sm font-bold text-gray-800">Paquetes</h3>
        <button type="button" data-action="click->pre-alerta-editor#addPaquete"
                class="inline-flex items-center gap-1 text-sm text-cec-teal hover:text-cec-teal-dark font-medium">
          <%= heroicon "plus-circle", variant: :outline, options: { class: "w-4 h-4" } %>
          Agregar
        </button>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Tracking</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Descripcion</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Instrucciones</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
              <th class="px-4 py-2"></th>
            </tr>
          </thead>
          <tbody data-pre-alerta-editor-target="paquetesBody" class="divide-y divide-gray-200">
            <% @pre_alerta.pre_alerta_paquetes.each.with_index do |pap, index| %>
              <tr class="paquete-row">
                <td class="px-4 py-2">
                  <%= f.fields_for :pre_alerta_paquetes, pap, child_index: index do |pf| %>
                    <%= pf.text_field :tracking, placeholder: "Ej. 1Z999AA1...",
                        class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
                  <% end %>
                </td>
                <td class="px-4 py-2">
                  <%= f.fields_for :pre_alerta_paquetes, pap, child_index: index do |pf| %>
                    <%= pf.text_field :descripcion, placeholder: "Descripcion",
                        class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
                  <% end %>
                </td>
                <td class="px-4 py-2">
                  <%= f.fields_for :pre_alerta_paquetes, pap, child_index: index do |pf| %>
                    <%= pf.text_area :instrucciones, placeholder: "Instrucciones", rows: 2,
                        class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal" %>
                  <% end %>
                </td>
                <td class="px-4 py-2">
                  <%= f.fields_for :pre_alerta_paquetes, pap, child_index: index do |pf| %>
                    <%= pf.date_field :fecha, class: "block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal", data: { controller: "flatpickr" } %>
                  <% end %>
                </td>
                <td class="px-4 py-2 text-center">
                  <button type="button" data-action="click->pre-alerta-editor#removePaquete" class="text-red-400 hover:text-red-600">
                    <%= heroicon "trash", variant: :outline, options: { class: "w-4 h-4" } %>
                  </button>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <template data-pre-alerta-editor-target="template">
        <tr class="paquete-row" data-new-record="true">
          <td class="px-4 py-2">
            <input type="text" name="pre_alerta[pre_alerta_paquetes_attributes][NEW_INDEX][tracking]"
                   placeholder="Ej. 1Z999AA1..."
                   class="block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
          </td>
          <td class="px-4 py-2">
            <input type="text" name="pre_alerta[pre_alerta_paquetes_attributes][NEW_INDEX][descripcion]"
                   placeholder="Descripcion"
                   class="block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
          </td>
          <td class="px-4 py-2">
            <textarea name="pre_alerta[pre_alerta_paquetes_attributes][NEW_INDEX][instrucciones]"
                      rows="2" placeholder="Instrucciones"
                      class="block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal"></textarea>
          </td>
          <td class="px-4 py-2">
            <input type="date" name="pre_alerta[pre_alerta_paquetes_attributes][NEW_INDEX][fecha]"
                   data-controller="flatpickr"
                   class="block w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-cec-teal focus:border-cec-teal">
          </td>
          <td class="px-4 py-2 text-center">
            <button type="button" data-action="click->pre-alerta-editor#removePaquete" class="text-red-400 hover:text-red-600">
              <%= heroicon "trash", variant: :outline, options: { class: "w-4 h-4" } %>
            </button>
          </td>
        </tr>
      </template>
    </div>

    <%# Actions %>
    <div class="flex gap-3 justify-end">
      <%= link_to "Cancelar", pre_alertas_path, class: "text-gray-600 hover:text-gray-800 text-sm font-medium px-4 py-2.5" %>
      <button type="submit" class="bg-cec-navy text-white font-semibold px-6 py-2.5 rounded-lg shadow-sm text-sm hover:bg-cec-navy-light transition-colors">
        Crear Pre-Alerta
      </button>
    </div>
  <% end %>
</div>
