<div class="min-h-screen flex flex-col lg:flex-row">

  <%# ========== LEFT: Hero Section (desktop only) ========== %>
  <div class="hidden lg:flex lg:w-[55%] relative overflow-hidden">
    <%= image_tag "login-hero.jpg",
        alt: "Cargo containers",
        class: "object-cover w-full h-full absolute inset-0" %>
    <div class="absolute inset-0 bg-gradient-to-t from-cec-navy-dark/90 via-cec-navy/40 to-transparent"></div>
    <div class="absolute bottom-12 left-12 z-10">
      <h1 class="text-4xl font-bold text-white tracking-tight">Compras Express Cargo</h1>
      <p class="text-lg text-gray-300 mt-2">Reempaque inteligente, ahorro real.</p>
    </div>
  </div>

  <%# ========== MOBILE: Top banner ========== %>
  <div class="lg:hidden h-48 relative overflow-hidden">
    <%= image_tag "login-hero.jpg",
        alt: "Cargo containers",
        class: "object-cover w-full h-full" %>
    <div class="absolute inset-0 bg-cec-navy/70"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-white">
      <h1 class="text-2xl font-bold tracking-tight">Compras Express Cargo</h1>
      <p class="text-sm text-gray-300 mt-1">Reempaque inteligente, ahorro real.</p>
    </div>
  </div>

  <%# ========== RIGHT: Forgot Password Form ========== %>
  <div class="flex-1 flex items-center justify-center p-6 lg:p-12 bg-white relative">
    <div class="w-full max-w-md animate-fade-in-up">

      <%# Icon %>
      <div class="flex items-center justify-center mb-8">
        <div class="w-14 h-14 bg-cec-gold/10 rounded-2xl flex items-center justify-center">
          <%= heroicon "key", variant: :solid, options: { class: "w-8 h-8 text-cec-gold" } %>
        </div>
      </div>

      <%# Heading %>
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-cec-navy">Recuperar contrasena</h2>
        <p class="text-sm text-gray-500 mt-1">Ingresa tu correo para recibir instrucciones</p>
      </div>

      <%# Flash messages %>
      <% if alert = flash[:alert] %>
        <div class="mb-6 p-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl flex items-center gap-2">
          <%= heroicon "exclamation-circle", variant: :mini, options: { class: "w-5 h-5 shrink-0" } %>
          <span><%= alert %></span>
        </div>
      <% end %>

      <%# Form %>
      <%= form_with url: passwords_path, class: "space-y-5" do |form| %>
        <div>
          <label for="email_address" class="block text-sm font-medium text-gray-700 mb-1.5">
            Correo electronico
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <%= heroicon "envelope", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
            </div>
            <%= form.email_field :email_address,
                required: true,
                autofocus: true,
                autocomplete: "username",
                placeholder: "admin@comprasexpresscargo.com",
                value: params[:email_address],
                class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                       transition-all duration-200
                       focus:border-cec-gold focus:ring-2 focus:ring-cec-gold/20 focus:outline-none
                       placeholder:text-gray-400" %>
          </div>
        </div>

        <div>
          <button type="submit"
                  class="w-full rounded-xl bg-cec-gold px-4 py-3 text-sm font-bold text-cec-navy-dark
                         hover:bg-cec-gold-dark active:scale-[0.98] transition-all duration-200
                         cursor-pointer flex items-center justify-center gap-2">
            Enviar instrucciones
          </button>
        </div>

        <div class="text-center pt-1">
          <%= link_to "Volver a iniciar sesion", new_session_path,
              class: "text-sm text-gray-500 hover:text-cec-gold-dark transition-colors" %>
        </div>
      <% end %>
    </div>

    <%# Footer %>
    <p class="absolute bottom-6 left-0 right-0 text-center text-xs text-gray-400">
      Compras Express Cargo &copy; <%= Date.current.year %>
    </p>
  </div>
</div>
