<%= render PageHeaderComponent.new(title: "Recibos", subtitle: "#{@recibos.total_count} recibos") %>

<details class="mb-6 bg-white rounded-lg shadow">
  <summary class="px-6 py-3 cursor-pointer text-sm font-medium text-gray-700 hover:text-cec-navy flex items-center gap-2">
    <%= heroicon "funnel", variant: :outline, options: { class: "w-4 h-4" } %>
    Filtros
  </summary>
  <div class="px-6 py-4 border-t border-gray-200">
    <%= form_tag recibos_path, method: :get, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Desde</label>
        <%= date_field_tag :fecha_desde, params[:fecha_desde], class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Hasta</label>
        <%= date_field_tag :fecha_hasta, params[:fecha_hasta], class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-3 flex gap-3">
        <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg hover:bg-cec-navy-light text-sm font-medium">Aplicar</button>
        <%= link_to "Limpiar", recibos_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>
</details>

<% if @recibos.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Numero</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cliente</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Venta</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Metodo</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Monto</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recibos.each do |r| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to r.numero, r, class: "text-sm font-mono font-medium text-cec-navy hover:underline" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                <%= r.cliente.codigo %> <span class="text-gray-500"><%= r.cliente.nombre_completo %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-500">
                <%= link_to r.venta.numero, venta_path(r.venta), class: "hover:underline" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= r.created_at.strftime("%d/%m/%Y %H:%M") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= r.forma_pago.to_s.humanize %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                L. <%= number_with_delimiter(r.monto.to_f, precision: 2) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-4"><%= paginate @recibos %></div>
<% else %>
  <%= render EmptyStateComponent.new(
    title: "No hay recibos",
    description: "Los recibos se generan automaticamente al registrar pagos.",
    icon: "receipt-percent"
  ) %>
<% end %>
