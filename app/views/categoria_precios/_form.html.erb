<%= form_with model: @categoria, url: (@categoria.persisted? ? categoria_precio_path(@categoria) : categoria_precios_path), local: true do |f| %>
  <% if @categoria.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm">
      <%= @categoria.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow p-6 space-y-4">
    <div>
      <%= f.label :nombre, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :nombre, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm", required: true %>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <%= f.label :precio_libra_aereo, "Precio Aereo (LPS/lb)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :precio_libra_aereo, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <%= f.label :precio_libra_maritimo, "Precio Maritimo (LPS/lb)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :precio_libra_maritimo, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <%= f.label :precio_volumen, "Precio por Volumen", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :precio_volumen, step: 0.001, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
    </div>
  </div>

  <div class="mt-6 flex gap-3">
    <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium">Guardar</button>
    <%= link_to "Cancelar", categoria_precios_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
