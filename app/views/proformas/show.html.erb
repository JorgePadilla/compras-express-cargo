<div class="max-w-3xl mx-auto bg-white p-8 print:p-0 print:shadow-none shadow rounded-lg">
  <div class="flex justify-between items-start border-b border-gray-200 pb-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-cec-navy">Compras Express Cargo</h1>
      <p class="text-sm text-gray-500">Proforma</p>
    </div>
    <div class="text-right">
      <p class="font-mono font-bold text-lg"><%= @proforma.numero %></p>
      <p class="text-sm text-gray-500"><%= @proforma.created_at.strftime("%d/%m/%Y") %></p>
      <p class="text-sm mt-1"><%= render StatusBadgeComponent.new(status: @proforma.estado) %></p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6 text-sm">
    <div>
      <p class="text-gray-500">Cliente</p>
      <p class="font-medium"><%= @proforma.cliente.codigo %> — <%= @proforma.cliente.nombre_completo %></p>
    </div>
  </div>

  <% has_paquetes = @proforma.venta_items.any? { |i| i.paquete_id.present? } %>

  <table class="min-w-full border border-gray-200 mb-6">
    <thead class="bg-gray-50">
      <tr>
        <% if has_paquetes %>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-700 uppercase border-b">Guia</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-700 uppercase border-b">Tracking</th>
        <% end %>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-700 uppercase border-b">Concepto</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Peso</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Precio/Lb</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% @proforma.venta_items.each do |item| %>
        <tr>
          <% if has_paquetes %>
            <td class="px-4 py-2 text-sm font-mono"><%= item.paquete&.guia || "—" %></td>
            <td class="px-4 py-2 text-sm font-mono"><%= item.paquete ? truncate(item.paquete.tracking, length: 20) : "—" %></td>
          <% end %>
          <td class="px-4 py-2 text-sm"><%= item.concepto %></td>
          <td class="px-4 py-2 text-sm text-right"><%= item.peso_cobrar %></td>
          <td class="px-4 py-2 text-sm text-right"><%= @proforma.simbolo_moneda %> <%= number_with_delimiter(item.precio_libra.to_f, precision: 2) %></td>
          <td class="px-4 py-2 text-sm text-right"><%= @proforma.simbolo_moneda %> <%= number_with_delimiter(item.subtotal.to_f, precision: 2) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot class="bg-gray-50">
      <tr>
        <td colspan="<%= has_paquetes ? 5 : 3 %>" class="px-4 py-2 text-right text-sm">Subtotal</td>
        <td class="px-4 py-2 text-right text-sm"><%= @proforma.simbolo_moneda %> <%= number_with_delimiter(@proforma.subtotal.to_f, precision: 2) %></td>
      </tr>
      <tr>
        <td colspan="<%= has_paquetes ? 5 : 3 %>" class="px-4 py-2 text-right text-sm">ISV (15%)</td>
        <td class="px-4 py-2 text-right text-sm"><%= @proforma.simbolo_moneda %> <%= number_with_delimiter(@proforma.impuesto.to_f, precision: 2) %></td>
      </tr>
      <tr>
        <td colspan="<%= has_paquetes ? 5 : 3 %>" class="px-4 py-2 text-right font-bold">Total</td>
        <td class="px-4 py-2 text-right font-bold text-cec-navy"><%= @proforma.simbolo_moneda %> <%= number_with_delimiter(@proforma.total.to_f, precision: 2) %></td>
      </tr>
    </tfoot>
  </table>

  <% if @proforma.notas.present? %>
    <div class="mb-4 text-sm">
      <p class="text-gray-500">Notas</p>
      <p><%= @proforma.notas %></p>
    </div>
  <% end %>

  <div class="flex flex-wrap gap-3 print:hidden">
    <%= link_to "Descargar PDF", pdf_proforma_path(@proforma), class: "px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium" %>
    <button onclick="window.print()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50">Imprimir</button>

    <% if @proforma.proforma? %>
      <%= link_to "Editar", edit_proforma_path(@proforma), class: "px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50" %>
      <%= button_to "Emitir como Factura", emitir_proforma_path(@proforma), method: :post,
          class: "px-4 py-2 bg-cec-teal text-white rounded-lg text-sm font-medium hover:bg-cec-teal-dark",
          data: { turbo_confirm: "¿Emitir esta proforma como factura? Se cargara al saldo del cliente." } %>
      <%= button_to "Anular", anular_proforma_path(@proforma), method: :delete,
          class: "px-4 py-2 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm font-medium",
          data: { turbo_confirm: "¿Anular esta proforma?" } %>
    <% end %>

    <% if @proforma.cliente.email.present? %>
      <%= button_to "Enviar Email", enviar_email_proforma_path(@proforma), method: :post,
          class: "px-4 py-2 bg-white border border-cec-teal text-cec-teal rounded-lg text-sm font-medium hover:bg-cec-teal/5" %>
    <% end %>

    <%= link_to "Volver", proformas_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
</div>
