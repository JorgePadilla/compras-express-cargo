<% content_for :title, "Proforma #{@venta.numero}" %>

<h2 style="margin:0 0 12px 0; font-size:18px; color:#0f2b5b;">Hola, <%= @cliente.nombre %></h2>

<p style="margin:0 0 16px 0; line-height:1.5;">
  Hemos preparado una proforma para ti. Adjunto encontraras el PDF con el detalle completo.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin:16px 0; background:#f9fafb; border-radius:6px;">
  <tr>
    <td style="padding:12px 16px; border-bottom:1px solid #e5e7eb;"><strong>Proforma:</strong></td>
    <td align="right" style="padding:12px 16px; border-bottom:1px solid #e5e7eb;"><%= @venta.numero %></td>
  </tr>
  <tr>
    <td style="padding:12px 16px; font-size:16px; color:#0f2b5b;"><strong>Total:</strong></td>
    <td align="right" style="padding:12px 16px; font-size:16px; color:#0f2b5b;"><strong><%= @venta.moneda %> <%= number_with_delimiter(format("%.2f", @venta.total)) %></strong></td>
  </tr>
</table>

<p style="margin:16px 0 0 0; font-size:13px; color:#6b7280;">
  Gracias por confiar en <%= @empresa.nombre %>.
</p>
