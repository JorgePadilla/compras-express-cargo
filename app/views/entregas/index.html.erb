<%= render PageHeaderComponent.new(title: "Entregas", subtitle: "#{@entregas.total_count} entregas") %>

<div class="mb-6">
  <%= render SearchBarComponent.new(url: entregas_path, placeholder: "Buscar por numero, cliente o receptor...", value: params[:q]) %>
</div>

<details class="mb-6 bg-white rounded-lg shadow">
  <summary class="px-6 py-3 cursor-pointer text-sm font-medium text-gray-700 hover:text-cec-navy flex items-center gap-2">
    <%= heroicon "funnel", variant: :outline, options: { class: "w-4 h-4" } %>
    Filtros
  </summary>
  <div class="px-6 py-4 border-t border-gray-200">
    <%= form_tag entregas_path, method: :get, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
        <%= select_tag :estado, options_for_select(Entrega::ESTADOS.map { |e| [e.humanize, e] }, params[:estado]),
            include_blank: "— Todos —",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Repartidor</label>
        <%= select_tag :repartidor_id, options_from_collection_for_select(User.where(rol: "entrega_despacho").order(:nombre), :id, :nombre, params[:repartidor_id]),
            include_blank: "— Todos —",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-3 flex gap-3">
        <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg hover:bg-cec-navy-light text-sm font-medium">Aplicar</button>
        <%= link_to "Limpiar", entregas_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>
</details>

<div class="mb-4">
  <%= link_to new_entrega_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-cec-teal text-white rounded-lg text-sm font-medium hover:bg-cec-teal-dark" do %>
    <%= heroicon "plus", variant: :mini, options: { class: "w-4 h-4" } %>
    Nueva Entrega
  <% end %>
</div>

<% if @entregas.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Numero</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cliente</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Receptor</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Paquetes</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @entregas.each do |e| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to e.numero, e, class: "text-sm font-mono font-medium text-cec-navy hover:underline" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-gray-700"><%= e.cliente.codigo %></span>
                <span class="text-sm text-gray-500 hidden sm:inline ml-1"><%= e.cliente.nombre_completo %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render StatusBadgeComponent.new(status: e.tipo_entrega) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render StatusBadgeComponent.new(status: e.estado) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= e.receptor_nombre %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= e.created_at.strftime("%d/%m/%Y") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-center text-sm"><%= e.paquetes.size %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-4"><%= paginate @entregas %></div>
<% else %>
  <%= render EmptyStateComponent.new(
    title: "No hay entregas registradas",
    description: "Crea una entrega seleccionando paquetes facturados de un cliente.",
    icon: "truck"
  ) %>
<% end %>
