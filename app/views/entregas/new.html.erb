<%= render PageHeaderComponent.new(title: "Nueva Entrega") %>

<% unless @cliente %>
  <div class="max-w-lg mx-auto bg-white p-6 rounded-lg shadow">
    <h2 class="text-lg font-semibold text-cec-navy mb-4">Seleccionar Cliente</h2>
    <%= form_with url: new_entrega_path, method: :get, class: "flex gap-3", local: true do |f| %>
      <div class="flex-1">
        <%= f.search_field :q, value: params[:q], placeholder: "Buscar por codigo o nombre...",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium">Buscar</button>
    <% end %>

    <% if params[:q].present? %>
      <% clientes = Cliente.activos.buscar(params[:q]).limit(10) %>
      <% if clientes.any? %>
        <ul class="mt-4 divide-y divide-gray-200">
          <% clientes.each do |c| %>
            <li class="py-3 flex justify-between items-center">
              <div>
                <span class="font-mono text-sm font-medium"><%= c.codigo %></span>
                <span class="text-sm text-gray-700 ml-2"><%= c.nombre_completo %></span>
              </div>
              <%= link_to "Seleccionar", new_entrega_path(cliente_id: c.id),
                  class: "text-sm text-cec-teal hover:underline font-medium" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-4 text-sm text-gray-500">No se encontraron clientes.</p>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="max-w-3xl mx-auto bg-white p-6 rounded-lg shadow">
    <div class="mb-4 pb-4 border-b border-gray-200">
      <p class="text-sm text-gray-500">Cliente</p>
      <p class="font-medium"><%= @cliente.codigo %> — <%= @cliente.nombre_completo %></p>
      <%= link_to "Cambiar cliente", new_entrega_path, class: "text-xs text-cec-teal hover:underline" %>
    </div>

    <% if @paquetes.any? %>
      <%= form_with url: entregas_path, method: :post, local: true do |f| %>
        <%= hidden_field_tag "entrega[cliente_id]", @cliente.id %>

        <h3 class="text-sm font-semibold text-gray-700 mb-3">Paquetes Facturados Disponibles</h3>
        <div class="overflow-x-auto mb-6">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-2 text-center w-10">
                  <input type="checkbox" id="select-all" class="rounded border-gray-300">
                </th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Guia</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Tracking</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Descripcion</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
                <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Peso</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @paquetes.each do |p| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-2 text-center">
                    <input type="checkbox" name="paquete_ids[]" value="<%= p.id %>" class="paquete-check rounded border-gray-300">
                  </td>
                  <td class="px-4 py-2 font-mono"><%= p.guia %></td>
                  <td class="px-4 py-2 text-gray-600 text-xs"><%= truncate(p.tracking, length: 20) %></td>
                  <td class="px-4 py-2"><%= p.descripcion %></td>
                  <td class="px-4 py-2"><%= p.tipo_envio&.nombre %></td>
                  <td class="px-4 py-2 text-right"><%= p.peso_cobrar %> lbs</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Entrega</label>
            <%= f.select :tipo_entrega, Entrega::TIPOS.map { |t| [t.humanize, t] }, {},
                name: "entrega[tipo_entrega]",
                class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Repartidor</label>
            <%= select_tag "entrega[repartidor_id]",
                options_from_collection_for_select(User.where(rol: "entrega_despacho").order(:nombre), :id, :nombre),
                include_blank: "— Seleccionar (domicilio) —",
                class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre del Receptor *</label>
            <%= text_field_tag "entrega[receptor_nombre]", @cliente.nombre_completo,
                required: true, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Identidad del Receptor *</label>
            <%= text_field_tag "entrega[receptor_identidad]", @cliente.identidad,
                required: true, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Direccion de Entrega (domicilio)</label>
            <%= text_area_tag "entrega[direccion_entrega]", @cliente.direccion,
                rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Notas</label>
            <%= text_area_tag "entrega[notas]", "", rows: 2,
                class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
          </div>
        </div>

        <div class="flex gap-3">
          <button type="submit" class="px-4 py-2 bg-cec-teal text-white rounded-lg text-sm font-medium hover:bg-cec-teal-dark">Crear Entrega</button>
          <%= link_to "Cancelar", entregas_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
        </div>
      <% end %>

      <script>
        document.getElementById('select-all')?.addEventListener('change', function() {
          document.querySelectorAll('.paquete-check').forEach(cb => cb.checked = this.checked);
        });
      </script>
    <% else %>
      <%= render EmptyStateComponent.new(
        title: "Sin paquetes entregables",
        description: "Este cliente no tiene paquetes facturados disponibles para entrega.",
        icon: "archive-box"
      ) %>
      <%= link_to "Volver", entregas_path, class: "mt-4 inline-block text-sm text-cec-teal hover:underline" %>
    <% end %>
  </div>
<% end %>
