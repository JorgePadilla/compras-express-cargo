<%= render PageHeaderComponent.new(title: "Editar Entrega #{@entrega.numero}") %>

<div class="max-w-2xl mx-auto bg-white p-6 rounded-lg shadow">
  <%= form_with model: @entrega, local: true do |f| %>
    <% if @entrega.errors.any? %>
      <div class="mb-4 p-3 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm">
        <ul class="list-disc pl-4">
          <% @entrega.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Entrega</label>
        <%= f.select :tipo_entrega, Entrega::TIPOS.map { |t| [t.humanize, t] },
            {}, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Repartidor</label>
        <%= f.select :repartidor_id,
            options_from_collection_for_select(User.where(rol: "entrega_despacho").order(:nombre), :id, :nombre, @entrega.repartidor_id),
            { include_blank: "— Seleccionar —" },
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nombre del Receptor *</label>
        <%= f.text_field :receptor_nombre, required: true,
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Identidad del Receptor *</label>
        <%= f.text_field :receptor_identidad, required: true,
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-700 mb-1">Direccion de Entrega</label>
        <%= f.text_area :direccion_entrega, rows: 2,
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-700 mb-1">Notas</label>
        <%= f.text_area :notas, rows: 2,
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
    </div>

    <div class="flex gap-3">
      <button type="submit" class="px-4 py-2 bg-cec-teal text-white rounded-lg text-sm font-medium hover:bg-cec-teal-dark">Guardar</button>
      <%= link_to "Cancelar", @entrega, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>
