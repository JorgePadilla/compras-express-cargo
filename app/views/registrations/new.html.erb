<div class="min-h-screen flex flex-col lg:flex-row">

  <%# ========== LEFT: Hero Section (desktop only) ========== %>
  <div class="hidden lg:flex lg:w-[55%] relative overflow-hidden">
    <%= image_tag "login-hero.jpg",
        alt: "Cargo containers",
        class: "object-cover w-full h-full absolute inset-0" %>
    <div class="absolute inset-0 bg-gradient-to-t from-cec-navy-dark/90 via-cec-navy/40 to-transparent"></div>
    <div class="absolute bottom-12 left-12 z-10">
      <h1 class="text-4xl font-bold text-white tracking-tight">Compras Express Cargo</h1>
      <p class="text-lg text-gray-300 mt-2">Reempaque inteligente, ahorro real.</p>
    </div>
  </div>

  <%# ========== MOBILE: Top banner ========== %>
  <div class="lg:hidden h-48 relative overflow-hidden">
    <%= image_tag "login-hero.jpg",
        alt: "Cargo containers",
        class: "object-cover w-full h-full" %>
    <div class="absolute inset-0 bg-cec-navy/70"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-white">
      <h1 class="text-2xl font-bold tracking-tight">Compras Express Cargo</h1>
      <p class="text-sm text-gray-300 mt-1">Reempaque inteligente, ahorro real.</p>
    </div>
  </div>

  <%# ========== RIGHT: Registration Form ========== %>
  <div class="flex-1 flex items-center justify-center p-6 lg:p-12 bg-white relative">
    <div class="w-full max-w-md">

      <%# Logo icon %>
      <div class="flex items-center justify-center mb-8">
        <div class="w-14 h-14 bg-gradient-to-br from-cec-gold/20 to-cec-teal/10 rounded-2xl flex items-center justify-center shadow-lg shadow-cec-gold/10">
          <%= heroicon "user-plus", variant: :solid, options: { class: "w-8 h-8 text-cec-gold" } %>
        </div>
      </div>

      <%# Heading %>
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-cec-navy">Crear Tu Cuenta</h2>
        <p class="text-sm text-gray-500 mt-1">Registrate para comenzar a enviar tus paquetes</p>
      </div>

      <%# Error messages %>
      <% if @cliente.errors.any? %>
        <div class="mb-6 p-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl">
          <div class="flex items-center gap-2 mb-2">
            <%= heroicon "exclamation-circle", variant: :mini, options: { class: "w-5 h-5 shrink-0" } %>
            <span class="font-medium">Se encontraron <%= @cliente.errors.count %> error(es):</span>
          </div>
          <ul class="list-disc list-inside space-y-1">
            <% @cliente.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Registration form %>
      <%= form_with model: @cliente, url: registro_path, class: "space-y-5" do |f| %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="cliente_nombre" class="block text-sm font-medium text-gray-700 mb-1.5">Nombre</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                <%= heroicon "user", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
              </div>
              <%= f.text_field :nombre, required: true, placeholder: "Tu nombre",
                  class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                         transition-all duration-200
                         focus:border-cec-teal focus:ring-2 focus:ring-cec-teal/20 focus:outline-none
                         placeholder:text-gray-400" %>
            </div>
          </div>

          <div>
            <label for="cliente_apellido" class="block text-sm font-medium text-gray-700 mb-1.5">Apellido</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                <%= heroicon "user", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
              </div>
              <%= f.text_field :apellido, required: true, placeholder: "Tu apellido",
                  class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                         transition-all duration-200
                         focus:border-cec-teal focus:ring-2 focus:ring-cec-teal/20 focus:outline-none
                         placeholder:text-gray-400" %>
            </div>
          </div>
        </div>

        <div>
          <label for="cliente_email" class="block text-sm font-medium text-gray-700 mb-1.5">Correo electronico</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <%= heroicon "envelope", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
            </div>
            <%= f.email_field :email, required: true, placeholder: "tu@email.com",
                class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                       transition-all duration-200
                       focus:border-cec-teal focus:ring-2 focus:ring-cec-teal/20 focus:outline-none
                       placeholder:text-gray-400" %>
          </div>
        </div>

        <div>
          <label for="cliente_telefono" class="block text-sm font-medium text-gray-700 mb-1.5">Telefono</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <%= heroicon "phone", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
            </div>
            <%= f.text_field :telefono, required: true, placeholder: "9999-8888",
                class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                       transition-all duration-200
                       focus:border-cec-teal focus:ring-2 focus:ring-cec-teal/20 focus:outline-none
                       placeholder:text-gray-400" %>
          </div>
        </div>

        <div>
          <label for="cliente_password" class="block text-sm font-medium text-gray-700 mb-1.5">Contrasena</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <%= heroicon "lock-closed", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
            </div>
            <%= f.password_field :password, required: true, autocomplete: "new-password",
                placeholder: "Minimo 8 caracteres",
                class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                       transition-all duration-200
                       focus:border-cec-teal focus:ring-2 focus:ring-cec-teal/20 focus:outline-none
                       placeholder:text-gray-400" %>
          </div>
        </div>

        <div>
          <label for="cliente_password_confirmation" class="block text-sm font-medium text-gray-700 mb-1.5">Confirmar contrasena</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <%= heroicon "lock-closed", variant: :outline, options: { class: "w-5 h-5 text-gray-400" } %>
            </div>
            <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
                placeholder: "Repite tu contrasena",
                class: "block w-full rounded-xl border border-gray-300 pl-11 pr-4 py-3 text-sm
                       transition-all duration-200
                       focus:border-cec-teal focus:ring-2 focus:ring-cec-teal/20 focus:outline-none
                       placeholder:text-gray-400" %>
          </div>
        </div>

        <div>
          <button type="submit"
                  class="w-full rounded-xl btn-gold-gradient px-4 py-3 text-sm font-bold text-cec-navy-dark
                         shadow-md shadow-cec-gold/25 active:scale-[0.98] transition-all duration-200
                         cursor-pointer flex items-center justify-center gap-2">
            Crear Mi Cuenta
          </button>
        </div>

        <div class="text-center pt-1">
          <%= link_to "Ya tienes cuenta? Inicia sesion", new_session_path,
              class: "text-sm text-gray-500 hover:text-cec-gold-dark transition-colors" %>
        </div>
      <% end %>
    </div>

    <%# Footer %>
    <p class="absolute bottom-6 left-0 right-0 text-center text-xs text-gray-400">
      Compras Express Cargo &copy; <%= Date.current.year %>
    </p>
  </div>
</div>
