<%= render PageHeaderComponent.new(title: "Editar Empresa") %>

<%= form_with model: @empresa, url: empresa_path, method: :patch, local: true, multipart: true do |f| %>
  <% if @empresa.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm">
      <%= @empresa.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="md:col-span-2">
        <%= f.label :nombre, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :nombre, required: true, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <%= f.label :rtn, "RTN", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :rtn, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <%= f.label :telefono, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :telefono, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :email_contacto, "Email de contacto", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email_contacto, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :direccion, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :direccion, rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <%= f.label :ciudad, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :ciudad, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <%= f.label :pais, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :pais, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <%= f.label :moneda_default, "Moneda default", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :moneda_default, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <%= f.label :isv_rate, "ISV (0-1, ej: 0.15)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :isv_rate, step: 0.0001, min: 0, max: 0.9999, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :sitio_web, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.url_field :sitio_web, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :terminos_factura, "Terminos al pie de factura", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :terminos_factura, rows: 3, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :logo, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.file_field :logo, accept: "image/png,image/jpeg", class: "block w-full text-sm" %>
        <% if @empresa.logo.attached? %>
          <div class="mt-2 text-xs text-gray-500">Logo actual: <%= @empresa.logo.filename.to_s %></div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex gap-3">
    <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium hover:bg-cec-navy-light">Guardar</button>
    <%= link_to "Cancelar", empresa_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
