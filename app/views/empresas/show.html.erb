<%= render PageHeaderComponent.new(title: "Datos de la Empresa", subtitle: "Informacion fiscal que aparece en facturas y recibos") do |h| %>
  <% h.with_action do %>
    <%= link_to "Editar", edit_empresa_path, class: "px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium hover:bg-cec-navy-light" %>
  <% end %>
<% end %>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Nombre</p>
      <p class="text-sm font-medium text-gray-900"><%= @empresa.nombre %></p>
    </div>
    <div>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">RTN</p>
      <p class="text-sm font-mono"><%= @empresa.rtn.presence || "—" %></p>
    </div>
    <div>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Telefono</p>
      <p class="text-sm"><%= @empresa.telefono.presence || "—" %></p>
    </div>
    <div>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Email de contacto</p>
      <p class="text-sm"><%= @empresa.email_contacto.presence || "—" %></p>
    </div>
    <div class="md:col-span-2">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Direccion</p>
      <p class="text-sm"><%= @empresa.direccion.presence || "—" %></p>
    </div>
    <div>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Ciudad</p>
      <p class="text-sm"><%= @empresa.ciudad %></p>
    </div>
    <div>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Pais</p>
      <p class="text-sm"><%= @empresa.pais %></p>
    </div>
    <div>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Moneda default</p>
      <p class="text-sm"><%= @empresa.moneda_default %></p>
    </div>
    <div>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">ISV</p>
      <p class="text-sm"><%= (@empresa.isv_rate.to_f * 100).round(2) %>%</p>
    </div>
    <div class="md:col-span-2">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Sitio web</p>
      <p class="text-sm"><%= @empresa.sitio_web.presence || "—" %></p>
    </div>
    <div class="md:col-span-2">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Terminos de factura</p>
      <p class="text-sm whitespace-pre-wrap"><%= @empresa.terminos_factura.presence || "—" %></p>
    </div>
  </div>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <h3 class="text-sm font-semibold text-gray-700 mb-3">Logo</h3>
  <% if @empresa.logo.attached? %>
    <%= image_tag @empresa.logo, class: "max-w-xs h-auto border border-gray-200 rounded-lg" %>
  <% else %>
    <p class="text-sm text-gray-500">Sin logo cargado. Edita la empresa para subir uno.</p>
  <% end %>
</div>
