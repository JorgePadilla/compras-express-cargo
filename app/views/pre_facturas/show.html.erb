<div class="max-w-3xl mx-auto bg-white p-8 print:p-0 print:shadow-none shadow rounded-lg">
  <div class="flex justify-between items-start border-b border-gray-200 pb-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-cec-navy">Compras Express Cargo</h1>
      <p class="text-sm text-gray-500">Pre-Factura</p>
    </div>
    <div class="text-right">
      <p class="font-mono font-bold text-lg"><%= @pre_factura.numero %></p>
      <p class="text-sm text-gray-500"><%= @pre_factura.created_at.strftime("%d/%m/%Y") %></p>
      <p class="text-sm mt-1"><%= render StatusBadgeComponent.new(status: @pre_factura.estado) %></p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6 text-sm">
    <div>
      <p class="text-gray-500">Cliente</p>
      <p class="font-medium"><%= @pre_factura.cliente.codigo %> — <%= @pre_factura.cliente.nombre_completo %></p>
      <% if @pre_factura.cliente.email.present? %>
        <p class="text-gray-500 text-xs"><%= @pre_factura.cliente.email %></p>
      <% end %>
    </div>
    <div class="text-right">
      <p class="text-gray-500">Fecha de Trabajo</p>
      <p class="font-medium"><%= @pre_factura.fecha_trabajo&.strftime("%d/%m/%Y") || "—" %></p>
    </div>
  </div>

  <table class="min-w-full border border-gray-200 mb-6">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-700 uppercase border-b">Concepto</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Peso (lb)</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Precio/Lb</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-700 uppercase border-b">Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% @pre_factura.pre_factura_items.each do |item| %>
        <tr>
          <td class="px-4 py-2 text-sm"><%= item.concepto %></td>
          <td class="px-4 py-2 text-sm text-right"><%= item.peso_cobrar %></td>
          <td class="px-4 py-2 text-sm text-right">L. <%= number_with_delimiter(item.precio_libra.to_f, precision: 2) %></td>
          <td class="px-4 py-2 text-sm text-right">L. <%= number_with_delimiter(item.subtotal.to_f, precision: 2) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot class="bg-gray-50">
      <tr>
        <td colspan="3" class="px-4 py-2 text-right text-sm">Subtotal</td>
        <td class="px-4 py-2 text-right text-sm">L. <%= number_with_delimiter(@pre_factura.subtotal.to_f, precision: 2) %></td>
      </tr>
      <tr>
        <td colspan="3" class="px-4 py-2 text-right text-sm">ISV (15%)</td>
        <td class="px-4 py-2 text-right text-sm">L. <%= number_with_delimiter(@pre_factura.impuesto.to_f, precision: 2) %></td>
      </tr>
      <tr>
        <td colspan="3" class="px-4 py-2 text-right font-bold">Total</td>
        <td class="px-4 py-2 text-right font-bold text-cec-navy">L. <%= number_with_delimiter(@pre_factura.total.to_f, precision: 2) %></td>
      </tr>
    </tfoot>
  </table>

  <% if @pre_factura.notas.present? %>
    <div class="text-sm text-gray-600 mb-6">
      <strong>Notas:</strong> <%= @pre_factura.notas %>
    </div>
  <% end %>

  <div class="flex gap-3 print:hidden">
    <button onclick="window.print()" class="px-4 py-2 bg-cec-navy text-white rounded-lg text-sm font-medium">Imprimir</button>
    <%= link_to "Volver", pre_facturas_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
    <% unless @pre_factura.facturado? || @pre_factura.anulado? %>
      <%= link_to "Editar", edit_pre_factura_path(@pre_factura), class: "px-4 py-2 text-sm text-cec-navy hover:underline" %>
    <% end %>
  </div>
</div>
