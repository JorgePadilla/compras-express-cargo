<%= render PageHeaderComponent.new(title: "Pre-Factura #{@pre_factura.numero}", subtitle: "Cliente: #{@pre_factura.cliente.codigo} — #{@pre_factura.cliente.nombre_completo}") do |h| %>
  <% h.with_action do %>
    <%= render StatusBadgeComponent.new(status: @pre_factura.estado) %>
  <% end %>
<% end %>

<%= form_with model: @pre_factura, url: pre_factura_path(@pre_factura), method: :patch, local: true do |f| %>
  <% if @pre_factura.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm">
      <%= @pre_factura.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow overflow-hidden mb-6">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Concepto</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Peso</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Precio/Lb</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Subtotal</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <%= f.fields_for :pre_factura_items do |item_f| %>
          <tr>
            <td class="px-6 py-3">
              <%= item_f.hidden_field :id %>
              <%= item_f.text_field :concepto, class: "w-full rounded border-gray-300 text-sm", readonly: @pre_factura.facturado? || @pre_factura.anulado? %>
            </td>
            <td class="px-6 py-3">
              <%= item_f.number_field :peso_cobrar, step: 0.01, class: "w-24 rounded border-gray-300 text-sm text-right" %>
            </td>
            <td class="px-6 py-3">
              <%= item_f.number_field :precio_libra, step: 0.01, class: "w-24 rounded border-gray-300 text-sm text-right" %>
            </td>
            <td class="px-6 py-3 text-right text-sm font-medium">
              L. <%= number_with_delimiter(item_f.object.subtotal.to_f, precision: 2) %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot class="bg-gray-50">
        <tr>
          <td colspan="3" class="px-6 py-3 text-right text-sm font-medium">Subtotal</td>
          <td class="px-6 py-3 text-right text-sm font-medium">L. <%= number_with_delimiter(@pre_factura.subtotal.to_f, precision: 2) %></td>
        </tr>
        <tr>
          <td colspan="3" class="px-6 py-3 text-right text-sm font-medium">ISV (15%)</td>
          <td class="px-6 py-3 text-right text-sm font-medium">L. <%= number_with_delimiter(@pre_factura.impuesto.to_f, precision: 2) %></td>
        </tr>
        <tr>
          <td colspan="3" class="px-6 py-3 text-right text-base font-bold">Total</td>
          <td class="px-6 py-3 text-right text-base font-bold text-cec-navy">L. <%= number_with_delimiter(@pre_factura.total.to_f, precision: 2) %></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <label class="block text-sm font-medium text-gray-700 mb-1">Notas</label>
    <%= f.text_area :notas, rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
  </div>

  <div class="flex flex-wrap gap-3">
    <% unless @pre_factura.facturado? || @pre_factura.anulado? %>
      <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg hover:bg-cec-navy-light text-sm font-medium">Guardar</button>
    <% end %>

    <% if @pre_factura.creado? %>
      <%= button_to "Confirmar", confirmar_pre_factura_path(@pre_factura), method: :post,
          class: "px-4 py-2 bg-cec-teal text-white rounded-lg hover:bg-cec-teal-dark text-sm font-medium" %>
    <% end %>

    <% if @pre_factura.creado? || @pre_factura.pendiente? %>
      <%= button_to "Facturar", facturar_pre_factura_path(@pre_factura), method: :post,
          class: "px-4 py-2 bg-cec-gold text-cec-navy-dark rounded-lg hover:opacity-90 text-sm font-semibold",
          data: { turbo_confirm: "¿Generar venta a partir de esta pre-factura?" } %>
    <% end %>

    <% unless @pre_factura.facturado? || @pre_factura.anulado? %>
      <%= button_to "Anular", anular_pre_factura_path(@pre_factura), method: :delete,
          class: "px-4 py-2 bg-red-50 text-red-700 border border-red-200 rounded-lg hover:bg-red-100 text-sm font-medium",
          data: { turbo_confirm: "¿Anular la pre-factura?" } %>
    <% end %>

    <%= link_to "Ver imprimible", @pre_factura, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
