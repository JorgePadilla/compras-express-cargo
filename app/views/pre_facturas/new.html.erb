<%= render PageHeaderComponent.new(title: "Nueva Pre-Factura", subtitle: "Selecciona cliente y paquetes") %>

<% if @cliente.nil? %>
  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-lg font-semibold mb-4">Paso 1: Seleccionar Cliente</h2>
    <%= form_tag new_pre_factura_path, method: :get, class: "space-y-4" do %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Cliente</label>
        <%= select_tag :cliente_id,
            options_from_collection_for_select(Cliente.activos.order(:codigo), :id, ->(c) { "#{c.codigo} - #{c.nombre_completo}" }),
            include_blank: "— Selecciona un cliente —",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:ring-cec-teal focus:border-cec-teal" %>
      </div>
      <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg hover:bg-cec-navy-light text-sm font-medium">Continuar</button>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-semibold mb-2">Cliente: <%= @cliente.codigo %> — <%= @cliente.nombre_completo %></h2>
    <p class="text-sm text-gray-500">
      Categoria: <%= @cliente.categoria_precio&.nombre || "Sin categoria (usa precios base del tipo de envio)" %>
    </p>
    <% if @cliente.saldo_pendiente.to_f > 0 %>
      <p class="text-sm text-amber-700 mt-1">Saldo pendiente actual: L. <%= number_with_delimiter(@cliente.saldo_pendiente.to_f, precision: 2) %></p>
    <% end %>
  </div>

  <% if @paquetes_facturables.any? %>
    <%= form_tag pre_facturas_path, method: :post do %>
      <%= hidden_field_tag :cliente_id, @cliente.id %>
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left"><input type="checkbox" data-action="change->select-all#toggle" class="rounded"></th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Guia</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tracking</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Peso Cobrar</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Precio/Lb</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Subtotal</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @paquetes_facturables.each do |p| %>
                <%
                  precio = @cliente.categoria_precio&.precio_para(p.tipo_envio) || p.tipo_envio&.precio_libra || 0
                  subtotal = ((p.peso_cobrar || 0).to_d * precio.to_d).round(2)
                %>
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3">
                    <%= check_box_tag "paquete_ids[]", p.id, false, id: "paquete_#{p.id}", class: "rounded border-gray-300 text-cec-teal focus:ring-cec-teal" %>
                  </td>
                  <td class="px-6 py-3 font-mono text-sm"><%= p.guia %></td>
                  <td class="px-6 py-3 font-mono text-sm"><%= truncate(p.tracking, length: 20) %></td>
                  <td class="px-6 py-3 text-sm text-gray-600"><%= p.tipo_envio&.nombre || "—" %></td>
                  <td class="px-6 py-3 text-right text-sm"><%= p.peso_cobrar || "—" %></td>
                  <td class="px-6 py-3 text-right text-sm">L. <%= number_with_delimiter(precio.to_f, precision: 2) %></td>
                  <td class="px-6 py-3 text-right text-sm font-medium">L. <%= number_with_delimiter(subtotal.to_f, precision: 2) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-6 bg-white rounded-lg shadow p-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">Notas (opcional)</label>
        <%= text_area_tag "pre_factura[notas]", "", rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>

      <div class="mt-6 flex gap-3">
        <button type="submit" class="px-4 py-2 bg-cec-navy text-white rounded-lg hover:bg-cec-navy-light text-sm font-medium">Crear Pre-Factura</button>
        <%= link_to "Cancelar", pre_facturas_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  <% else %>
    <%= render EmptyStateComponent.new(
      title: "Sin paquetes facturables",
      description: "Este cliente no tiene paquetes en bodega Honduras disponibles para facturar.",
      icon: "archive-box"
    ) %>
  <% end %>
<% end %>
