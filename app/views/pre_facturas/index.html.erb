<%= render PageHeaderComponent.new(title: "Pre-Facturas", subtitle: "#{@pre_facturas.total_count} pre-facturas") do |h| %>
  <% h.with_action do %>
    <%= render ButtonComponent.new(href: new_pre_factura_path, variant: :primary, icon: "plus") do %>
      Nueva Pre-Factura
    <% end %>
  <% end %>
<% end %>

<div class="mb-6">
  <%= render SearchBarComponent.new(url: pre_facturas_path, placeholder: "Buscar por numero o cliente...", value: params[:q]) %>
</div>

<details class="mb-6 bg-white rounded-lg shadow">
  <summary class="px-6 py-3 cursor-pointer text-sm font-medium text-gray-700 hover:text-cec-navy flex items-center gap-2">
    <%= heroicon "funnel", variant: :outline, options: { class: "w-4 h-4" } %>
    Filtros
  </summary>
  <div class="px-6 py-4 border-t border-gray-200">
    <%= form_tag pre_facturas_path, method: :get, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do %>
      <% if params[:q].present? %>
        <input type="hidden" name="q" value="<%= params[:q] %>">
      <% end %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
        <%= select_tag :estado, options_for_select(PreFactura::ESTADOS.map { |e| [e.humanize, e] }, params[:estado]),
            include_blank: "— Todos —",
            class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:ring-cec-teal focus:border-cec-teal" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Desde</label>
        <%= date_field_tag :fecha_desde, params[:fecha_desde], class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Hasta</label>
        <%= date_field_tag :fecha_hasta, params[:fecha_hasta], class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm" %>
      </div>
      <div class="md:col-span-3 flex gap-3">
        <button type="submit" class="px-4 py-2 text-sm font-medium bg-cec-navy text-white rounded-lg hover:bg-cec-navy-light">Aplicar</button>
        <%= link_to "Limpiar", pre_facturas_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>
</details>

<% if @pre_facturas.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Numero</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cliente</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total (LPS)</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @pre_facturas.each do |pf| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to pf.numero, pf, class: "text-sm font-mono font-medium text-cec-navy hover:underline" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-gray-700"><%= pf.cliente.codigo %></span>
                <span class="text-sm text-gray-500 hidden sm:inline ml-1"><%= pf.cliente.nombre_completo %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-gray-500"><%= pf.fecha_trabajo&.strftime("%d/%m/%Y") || pf.created_at.strftime("%d/%m/%Y") %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render StatusBadgeComponent.new(status: pf.estado) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <span class="text-sm font-medium text-gray-900">L. <%= number_with_delimiter(pf.total.to_f, precision: 2) %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right space-x-2">
                <%= link_to "Ver", pf, class: "text-cec-teal hover:underline text-sm" %>
                <% unless pf.facturado? || pf.anulado? %>
                  <%= link_to "Editar", edit_pre_factura_path(pf), class: "text-cec-navy hover:underline text-sm" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-4"><%= paginate @pre_facturas %></div>
<% else %>
  <%= render EmptyStateComponent.new(
    title: "No hay pre-facturas",
    description: "Crea una pre-factura seleccionando paquetes en bodega Honduras.",
    icon: "document-text"
  ) %>
<% end %>
